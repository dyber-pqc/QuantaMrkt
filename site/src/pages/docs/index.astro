---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { SITE } from '../../lib/constants';
---

<MarketingLayout title="Documentation" description="Get started with QuantaMrkt. Quickstart guides, API reference, and open-source repositories.">

  <!-- Page Header -->
  <section class="py-24 text-center">
    <div class="mx-auto max-w-7xl px-6">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 rounded-full border border-electric/20 bg-electric/5 text-sm text-electric">
        Developer Docs
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
        <span class="gradient-text">Documentation</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Everything you need to integrate quantum-safe cryptography into your AI infrastructure.
      </p>
    </div>
  </section>

  <!-- Docs Cards -->
  <section class="pb-24">
    <div class="mx-auto max-w-4xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Quickstart -->
        <a href="/docs/quickstart" class="card-hover group flex flex-col">
          <div class="w-12 h-12 rounded-lg bg-electric/10 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-electric" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2 text-white">Quickstart</h3>
          <p class="text-sm text-gray-400 leading-relaxed flex-1">
            Get up and running in under 5 minutes. Install the SDK, create your first agent identity, and verify a model.
          </p>
          <span class="inline-flex items-center gap-1 text-electric text-sm mt-5 font-medium group-hover:gap-2 transition-all">
            Get started
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </a>

        <!-- API Reference -->
        <a href="/docs/api-reference" class="card-hover group flex flex-col">
          <div class="w-12 h-12 rounded-lg bg-quantum/10 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-quantum" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2 text-white">API Reference</h3>
          <p class="text-sm text-gray-400 leading-relaxed flex-1">
            Complete reference for the QuantaMrkt REST API, SDKs, and CLI. Authenticate, sign, verify, and manage models programmatically.
          </p>
          <span class="inline-flex items-center gap-1 text-quantum text-sm mt-5 font-medium group-hover:gap-2 transition-all">
            View reference
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </a>

        <!-- GitHub -->
        <a href={SITE.github} target="_blank" rel="noopener" class="card-hover group flex flex-col">
          <div class="w-12 h-12 rounded-lg bg-purple-500/10 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2 text-white">GitHub</h3>
          <p class="text-sm text-gray-400 leading-relaxed flex-1">
            Browse the source, report issues, and contribute to the open-source QuantaMrkt ecosystem.
          </p>
          <span class="inline-flex items-center gap-1 text-purple-400 text-sm mt-5 font-medium group-hover:gap-2 transition-all">
            View repository
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </span>
        </a>

      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="pb-24">
    <div class="mx-auto max-w-4xl px-6">
      <div class="card">
        <h2 class="text-lg font-bold mb-6">Popular Topics</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="/docs/quickstart" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/5 transition-colors group">
            <span class="w-8 h-8 rounded-md bg-electric/10 flex items-center justify-center shrink-0">
              <span class="text-electric text-sm font-mono font-bold">01</span>
            </span>
            <div>
              <p class="text-sm font-medium text-white group-hover:text-electric transition-colors">Install the SDK</p>
              <p class="text-xs text-gray-500">npm, pip, cargo, and go</p>
            </div>
          </a>
          <a href="/docs/quickstart#agent-identity" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/5 transition-colors group">
            <span class="w-8 h-8 rounded-md bg-electric/10 flex items-center justify-center shrink-0">
              <span class="text-electric text-sm font-mono font-bold">02</span>
            </span>
            <div>
              <p class="text-sm font-medium text-white group-hover:text-electric transition-colors">Create Agent Identity</p>
              <p class="text-xs text-gray-500">PQ-AID key generation</p>
            </div>
          </a>
          <a href="/docs/quickstart#verify-model" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/5 transition-colors group">
            <span class="w-8 h-8 rounded-md bg-quantum/10 flex items-center justify-center shrink-0">
              <span class="text-quantum text-sm font-mono font-bold">03</span>
            </span>
            <div>
              <p class="text-sm font-medium text-white group-hover:text-quantum transition-colors">Verify a Model</p>
              <p class="text-xs text-gray-500">Shield Registry verification</p>
            </div>
          </a>
          <a href="/docs/quickstart#migrate" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/5 transition-colors group">
            <span class="w-8 h-8 rounded-md bg-quantum/10 flex items-center justify-center shrink-0">
              <span class="text-quantum text-sm font-mono font-bold">04</span>
            </span>
            <div>
              <p class="text-sm font-medium text-white group-hover:text-quantum transition-colors">Run Your First Migration</p>
              <p class="text-xs text-gray-500">Migrator CLI quickstart</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

</MarketingLayout>
