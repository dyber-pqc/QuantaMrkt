---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { PRICING_TIERS } from '../lib/constants';
---

<MarketingLayout title="Pricing" description="Simple, transparent pricing for quantum-safe AI infrastructure. Start free, scale as you grow.">

  <!-- Page Header -->
  <section class="py-24 text-center">
    <div class="mx-auto max-w-7xl px-6">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 rounded-full border border-electric/20 bg-electric/5 text-sm text-electric">
        Simple Pricing
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Start free. <span class="gradient-text">Scale securely.</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Every plan includes post-quantum cryptography. No classical crypto fallbacks. No compromises.
      </p>
    </div>
  </section>

  <!-- Pricing Grid -->
  <section class="pb-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {PRICING_TIERS.map((tier) => (
          <div
            class:list={[
              'relative flex flex-col rounded-xl border p-8',
              tier.highlighted
                ? 'border-electric bg-navy-800 glow-electric'
                : 'border-white/5 bg-navy-800',
            ]}
          >
            {tier.highlighted && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="px-3 py-1 text-xs font-semibold rounded-full bg-electric text-navy-900">
                  Most Popular
                </span>
              </div>
            )}

            <div class="mb-6">
              <h3 class="text-lg font-bold mb-2">{tier.name}</h3>
              <div class="flex items-baseline gap-1">
                <span class:list={[
                  'text-4xl font-bold',
                  tier.highlighted ? 'text-electric' : 'text-white',
                ]}>
                  {tier.price}
                </span>
                {tier.period && (
                  <span class="text-gray-400 text-sm">{tier.period}</span>
                )}
              </div>
              <p class="text-sm text-gray-400 mt-3">{tier.description}</p>
            </div>

            <ul class="space-y-3 mb-8 flex-1">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-gray-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class:list={[
                    'w-5 h-5 shrink-0 mt-0.5',
                    tier.highlighted ? 'text-electric' : 'text-quantum',
                  ]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <a
              href={tier.name === 'Enterprise' ? 'mailto:sales@quantamrkt.com' : tier.name === 'Free' ? '/api/auth/login' : '/api/auth/login'}
              class:list={[
                'w-full text-center py-3 rounded-lg font-semibold text-sm transition-colors duration-200',
                tier.highlighted
                  ? 'bg-electric text-navy-900 hover:bg-electric-400'
                  : 'border border-white/10 text-gray-300 hover:bg-white/5',
              ]}
            >
              {tier.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ / Features Comparison -->
  <section class="py-24 border-t border-white/5">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">All plans include</h2>
        <p class="text-gray-400 text-lg">Quantum-safe security is not a premium feature. It is the baseline.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="card text-center">
          <div class="w-10 h-10 rounded-lg bg-electric/10 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-electric" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
          </div>
          <p class="text-sm font-medium text-white">PQC-Native Crypto</p>
          <p class="text-xs text-gray-400 mt-1">ML-DSA, ML-KEM, SLH-DSA</p>
        </div>
        <div class="card text-center">
          <div class="w-10 h-10 rounded-lg bg-quantum/10 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-quantum" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><path d="m9 15 2 2 4-4"/></svg>
          </div>
          <p class="text-sm font-medium text-white">FIPS 203/204/205</p>
          <p class="text-xs text-gray-400 mt-1">Full NIST compliance</p>
        </div>
        <div class="card text-center">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 8v8"/><path d="m8 12 4-4 4 4"/></svg>
          </div>
          <p class="text-sm font-medium text-white">HNDL Analysis</p>
          <p class="text-xs text-gray-400 mt-1">Risk scoring included</p>
        </div>
        <div class="card text-center">
          <div class="w-10 h-10 rounded-lg bg-electric/10 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-electric" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/></svg>
          </div>
          <p class="text-sm font-medium text-white">Transparency Log</p>
          <p class="text-xs text-gray-400 mt-1">Append-only audit trail</p>
        </div>
        <div class="card text-center">
          <div class="w-10 h-10 rounded-lg bg-quantum/10 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-quantum" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>
          </div>
          <p class="text-sm font-medium text-white">99.9% Uptime SLA</p>
          <p class="text-xs text-gray-400 mt-1">On paid plans</p>
        </div>
        <div class="card text-center">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
          </div>
          <p class="text-sm font-medium text-white">Open Source Core</p>
          <p class="text-xs text-gray-400 mt-1">Apache 2.0 licensed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Enterprise CTA -->
  <section class="py-24 border-t border-white/5">
    <div class="mx-auto max-w-7xl px-6">
      <div class="card glow-electric text-center py-16 px-8 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-electric/5 to-quantum/5 rounded-xl pointer-events-none"></div>
        <div class="relative z-10">
          <h2 class="section-heading mb-4">Need a custom solution?</h2>
          <p class="text-gray-400 text-lg max-w-xl mx-auto mb-8">
            On-premises deployment, custom integrations, and dedicated support for enterprise teams.
          </p>
          <a href="mailto:sales@quantamrkt.com" class="btn-primary text-base px-8 py-3.5">
            Contact Sales
          </a>
        </div>
      </div>
    </div>
  </section>

</MarketingLayout>
