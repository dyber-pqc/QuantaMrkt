---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { getBlocks, getLatestBlock, verifyBlockChain } from '../lib/pqc-chain';

const db = (Astro.locals as any).runtime?.env?.DB;

let blocks: any[] = [];
let totalBlocks = 0;
let latestBlock: any = null;
let chainValid = true;
let blocksChecked = 0;
let totalEntries = 0;

if (db) {
  try {
    const result = await getBlocks(db, { limit: 20, offset: 0 });
    blocks = result.blocks;
    totalBlocks = result.total;

    latestBlock = await getLatestBlock(db);

    if (totalBlocks > 0) {
      const verification = await verifyBlockChain(db);
      chainValid = verification.valid;
      blocksChecked = verification.blocks_checked;
    }

    // Calculate total entries
    const entryCount = await db
      .prepare('SELECT COUNT(*) as total FROM transparency_log')
      .first<{ total: number }>();
    totalEntries = entryCount?.total ?? 0;
  } catch (e) {
    // Graceful degradation - table may not exist yet
  }
}

function truncateHash(hash: string, len: number = 8): string {
  if (!hash || hash === '0') return '0x0';
  return hash.substring(0, len) + '...' + hash.substring(hash.length - 4);
}

function formatTime(timestamp: string): string {
  if (!timestamp) return '';
  try {
    const d = new Date(timestamp.replace(' ', 'T') + 'Z');
    return d.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  } catch {
    return timestamp;
  }
}
---

<MarketingLayout title="PQC Block Chain" description="Immutable, quantum-safe record of every action on QuantaMrkt. Every block is signed with ML-DSA-87.">
  <div class="mx-auto max-w-7xl px-6 py-12">

    <!-- Hero Section -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 rounded-full bg-purple-500/10 border border-purple-500/20 px-4 py-1.5 text-xs font-medium text-purple-400 mb-4">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        Post-Quantum Cryptography
      </div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-3">PQC Block Chain</h1>
      <p class="text-base text-gray-400 max-w-2xl mx-auto mb-6">
        Immutable, quantum-safe record of every action on QuantaMrkt. Every block is signed with ML-DSA-87.
      </p>

      <!-- Chain Status Bar -->
      <div class="inline-flex flex-wrap items-center justify-center gap-4 rounded-xl border border-white/5 bg-navy-800 px-6 py-3">
        <div class="flex items-center gap-2">
          {chainValid ? (
            <span class="flex h-3 w-3 rounded-full bg-green-400 shadow-[0_0_8px_rgba(74,222,128,0.5)]"></span>
            <span class="text-sm font-medium text-green-400">Chain Valid</span>
          ) : (
            <span class="flex h-3 w-3 rounded-full bg-red-400 shadow-[0_0_8px_rgba(248,113,113,0.5)]"></span>
            <span class="text-sm font-medium text-red-400">Chain Broken</span>
          )}
        </div>
        <span class="text-white/10">|</span>
        <div class="text-sm text-gray-400">
          <span class="text-white font-mono">{totalBlocks}</span> blocks
        </div>
        <span class="text-white/10">|</span>
        <div class="text-sm text-gray-400">
          <span class="text-white font-mono">{totalEntries}</span> entries
        </div>
        <span class="text-white/10 hidden sm:inline">|</span>
        <div class="text-sm text-gray-400 hidden sm:block">
          Latest: <code class="text-xs font-mono text-electric">{latestBlock ? truncateHash(latestBlock.block_hash, 12) : 'N/A'}</code>
        </div>
        <button
          id="verify-chain-btn"
          class="ml-2 rounded-lg bg-electric/10 px-3 py-1.5 text-xs font-medium text-electric hover:bg-electric/20 transition-colors border border-electric/20"
        >
          Verify Chain
        </button>
      </div>

      <!-- Verification Result -->
      <div id="verify-result" class="hidden mt-4 inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm"></div>
    </div>

    <!-- Chain Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-8">
      <div class="rounded-lg border border-white/5 bg-navy-800 px-4 py-3 text-center">
        <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Total Blocks</p>
        <p class="text-2xl font-bold text-white font-mono">{totalBlocks}</p>
      </div>
      <div class="rounded-lg border border-white/5 bg-navy-800 px-4 py-3 text-center">
        <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Total Entries</p>
        <p class="text-2xl font-bold text-white font-mono">{totalEntries}</p>
      </div>
      <div class="rounded-lg border border-white/5 bg-navy-800 px-4 py-3 text-center">
        <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Chain Verified</p>
        <p class:list={['text-2xl font-bold font-mono', chainValid ? 'text-green-400' : 'text-red-400']}>
          {chainValid ? 'Yes' : 'No'}
        </p>
      </div>
      <div class="rounded-lg border border-white/5 bg-navy-800 px-4 py-3 text-center">
        <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Latest Block</p>
        <p class="text-sm text-gray-300 font-mono">
          {latestBlock ? formatTime(latestBlock.timestamp) : 'N/A'}
        </p>
      </div>
    </div>

    <!-- Block Chain Visualization (top 5 blocks) -->
    {blocks.length > 0 && (
      <div class="mb-8 overflow-x-auto">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Recent Blocks</h2>
        <div class="flex items-center gap-0 min-w-max px-4">
          {blocks.slice(0, 5).reverse().map((block: any, i: number) => (
            <>
              <div class="flex flex-col items-center cursor-pointer block-card" data-block={block.block_number}>
                <div class:list={[
                  'rounded-lg border px-4 py-3 min-w-[200px] transition-colors hover:border-electric/30',
                  block.block_number === 0 ? 'border-purple-500/30 bg-purple-500/5' : 'border-white/10 bg-navy-800'
                ]}>
                  <div class="flex items-center justify-between mb-1">
                    <span class:list={[
                      'text-xs font-bold',
                      block.block_number === 0 ? 'text-purple-400' : 'text-white'
                    ]}>
                      Block #{block.block_number}
                    </span>
                    <span class="text-[10px] text-gray-600">{block.entries_count} entries</span>
                  </div>
                  <div class="text-xs font-mono text-gray-500 mb-1" title={block.block_hash}>
                    {truncateHash(block.block_hash, 10)}
                  </div>
                  <div class="text-[10px] text-gray-600">{formatTime(block.timestamp)}</div>
                </div>
                <div class="mt-1 text-[9px] text-gray-700 font-mono" title={block.previous_block_hash}>
                  prev: {truncateHash(block.previous_block_hash, 6)}
                </div>
              </div>
              {i < Math.min(blocks.length, 5) - 1 && (
                <div class="flex items-center px-1 -mt-4">
                  <div class="w-6 h-px bg-electric/30"></div>
                  <svg class="w-3 h-3 text-electric/50 -ml-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </div>
              )}
            </>
          ))}
        </div>
      </div>
    )}

    <!-- Block List -->
    <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden mb-8">
      <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/5">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">All Blocks</h2>
        <button
          id="mint-block-btn"
          class="rounded-lg bg-purple-500/10 px-3 py-1.5 text-xs font-medium text-purple-400 hover:bg-purple-500/20 transition-colors border border-purple-500/20"
        >
          Mint Block
        </button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/5 text-left">
              <th class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Block</th>
              <th class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Timestamp</th>
              <th class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Entries</th>
              <th class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Block Hash</th>
              <th class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Merkle Root</th>
              <th class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Prev Hash</th>
              <th class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Signature</th>
            </tr>
          </thead>
          <tbody id="blocks-tbody">
            {blocks.map((block: any) => (
              <tr
                class="border-b border-white/5 hover:bg-white/[0.02] cursor-pointer transition-colors block-row"
                data-block={block.block_number}
              >
                <td class="px-4 py-3">
                  <span class:list={[
                    'font-mono text-xs font-bold',
                    block.block_number === 0 ? 'text-purple-400' : 'text-white'
                  ]}>
                    #{block.block_number}
                  </span>
                  {block.block_number === 0 && (
                    <span class="ml-1.5 text-[9px] text-purple-400/60">GENESIS</span>
                  )}
                </td>
                <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">{block.timestamp}</td>
                <td class="px-4 py-3 text-xs text-gray-400 font-mono">
                  {block.entries_count}
                  {block.entries_count > 0 && (
                    <span class="text-gray-600 ml-1">({block.entry_range_start}-{block.entry_range_end})</span>
                  )}
                </td>
                <td class="px-4 py-3 font-mono text-xs text-electric" title={block.block_hash}>
                  {truncateHash(block.block_hash, 10)}
                </td>
                <td class="px-4 py-3 font-mono text-xs text-cyan-400" title={block.merkle_root}>
                  {truncateHash(block.merkle_root, 10)}
                </td>
                <td class="px-4 py-3 font-mono text-xs text-gray-600" title={block.previous_block_hash}>
                  {truncateHash(block.previous_block_hash, 8)}
                </td>
                <td class="px-4 py-3 font-mono text-xs text-purple-400" title={block.signature || ''}>
                  {block.signature ? truncateHash(block.signature, 8) : 'N/A'}
                </td>
              </tr>
            ))}
            {blocks.length === 0 && (
              <tr>
                <td colspan="7" class="px-4 py-12 text-center text-sm text-gray-500">
                  No blocks minted yet. The genesis block will be created when the first entry is added.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Block Detail Panel -->
    <div id="block-detail" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm">
      <div class="relative mx-4 w-full max-w-3xl max-h-[90vh] overflow-y-auto rounded-2xl border border-white/10 bg-navy-900 p-6 shadow-2xl">
        <button id="close-block-detail" class="absolute right-4 top-4 text-gray-500 hover:text-white transition-colors">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <h3 class="text-lg font-bold text-white mb-4">Block #<span id="detail-block-num"></span></h3>

        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <div class="text-xs text-gray-500 mb-1">Timestamp</div>
              <div id="detail-block-time" class="text-sm text-gray-300"></div>
            </div>
            <div>
              <div class="text-xs text-gray-500 mb-1">Entries</div>
              <div id="detail-block-entries" class="text-sm text-gray-300"></div>
            </div>
            <div>
              <div class="text-xs text-gray-500 mb-1">Signer DID</div>
              <div id="detail-block-signer" class="text-sm font-mono text-gray-300 break-all"></div>
            </div>
            <div>
              <div class="text-xs text-gray-500 mb-1">Entry Range</div>
              <div id="detail-block-range" class="text-sm font-mono text-gray-300"></div>
            </div>
          </div>

          <div class="border-t border-white/5 pt-3">
            <div class="text-xs font-medium text-white mb-2">Cryptographic Proof</div>
            <div class="rounded-lg bg-navy-800 p-4 space-y-2 font-mono text-xs">
              <div>
                <span class="text-gray-500">Block hash:    </span>
                <span id="detail-block-hash" class="text-electric break-all ml-1"></span>
              </div>
              <div>
                <span class="text-gray-500">Previous hash: </span>
                <span id="detail-block-prev" class="text-gray-300 break-all ml-1"></span>
              </div>
              <div>
                <span class="text-gray-500">Merkle root:   </span>
                <span id="detail-block-merkle" class="text-cyan-400 break-all ml-1"></span>
              </div>
              <div class="border-t border-white/5 pt-2 mt-2">
                <span class="text-gray-500">ML-DSA-87 sig: </span>
                <span id="detail-block-sig" class="text-purple-400 break-all ml-1"></span>
              </div>
            </div>
          </div>

          <!-- Block entries -->
          <div class="border-t border-white/5 pt-3">
            <div class="text-xs font-medium text-white mb-2">Entries in this Block</div>
            <div id="detail-block-entry-list" class="space-y-1">
              <div class="text-xs text-gray-500">Loading...</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- How It Works -->
    <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
      <div class="px-6 py-4 border-b border-white/5">
        <h2 class="text-sm font-semibold text-white">How the PQC Block Chain Works</h2>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-electric/10 text-electric mx-auto mb-3">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
            </div>
            <h3 class="text-xs font-semibold text-white mb-1">1. Entry Creation</h3>
            <p class="text-[10px] text-gray-500">Every model submission, agent registration, and verification is logged to the transparency log with a SHA-256 chain hash.</p>
          </div>
          <div class="text-center">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-cyan-500/10 text-cyan-400 mx-auto mb-3">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            </div>
            <h3 class="text-xs font-semibold text-white mb-1">2. Block Creation</h3>
            <p class="text-[10px] text-gray-500">Pending entries are grouped into blocks. A Merkle tree root is computed from all entry hashes in the block.</p>
          </div>
          <div class="text-center">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-purple-500/10 text-purple-400 mx-auto mb-3">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            </div>
            <h3 class="text-xs font-semibold text-white mb-1">3. ML-DSA Signing</h3>
            <p class="text-[10px] text-gray-500">Each block hash is signed with ML-DSA-87, a NIST-standardized post-quantum digital signature algorithm.</p>
          </div>
          <div class="text-center">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-500/10 text-green-400 mx-auto mb-3">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <h3 class="text-xs font-semibold text-white mb-1">4. Public Verification</h3>
            <p class="text-[10px] text-gray-500">Anyone can verify the chain integrity by re-computing hashes and Merkle roots. Use the API for programmatic verification.</p>
          </div>
        </div>

        <div class="mt-6 pt-4 border-t border-white/5">
          <h3 class="text-xs font-semibold text-white mb-2">Programmatic Verification</h3>
          <div class="rounded-lg bg-navy-900 p-4">
            <pre class="text-xs font-mono text-gray-400 overflow-x-auto"><code set:text={`curl https://quantamrkt.com/api/chain/verify
# {"valid": true, "blocks_checked": 4, "latest_block": {"block_number": 3, ...}}

curl https://quantamrkt.com/api/chain/blocks
# {"blocks": [...], "total": 4}

curl https://quantamrkt.com/api/chain/blocks/1
# {"block": {...}, "entries": [...]}`} /></pre>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Client-side interactivity -->
  <script>
    function truncHash(hash: string, len: number = 8): string {
      if (!hash || hash === '0') return '0x0';
      return hash.substring(0, len) + '...' + hash.substring(hash.length - 4);
    }

    function getActionColor(action: string): string {
      const colors: Record<string, string> = {
        'model:signed': 'text-green-400 bg-green-400/10 border-green-400/20',
        'model:verified': 'text-blue-400 bg-blue-400/10 border-blue-400/20',
        'model:created': 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20',
        'model:submitted': 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20',
        'agent:registered': 'text-purple-400 bg-purple-400/10 border-purple-400/20',
        'agent:revoked': 'text-red-400 bg-red-400/10 border-red-400/20',
        'manifest:pushed': 'text-cyan-400 bg-cyan-400/10 border-cyan-400/20',
      };
      return colors[action] || 'text-gray-400 bg-gray-400/10 border-gray-400/20';
    }

    // Verify Chain button
    document.getElementById('verify-chain-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('verify-chain-btn') as HTMLButtonElement;
      const resultEl = document.getElementById('verify-result')!;
      btn.textContent = 'Verifying...';
      btn.disabled = true;

      try {
        const res = await fetch('/api/chain/verify');
        const data = await res.json();

        resultEl.classList.remove('hidden');
        if (data.valid) {
          resultEl.className = 'mt-4 inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm bg-green-400/10 text-green-400 border border-green-400/20';
          resultEl.innerHTML = `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Chain integrity verified. ${data.blocks_checked} blocks checked.`;
        } else {
          resultEl.className = 'mt-4 inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm bg-red-400/10 text-red-400 border border-red-400/20';
          resultEl.innerHTML = `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg> Chain broken. ${data.errors?.join(', ') || 'Unknown error'}`;
        }
      } catch (e) {
        resultEl.classList.remove('hidden');
        resultEl.className = 'mt-4 inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm bg-yellow-400/10 text-yellow-400 border border-yellow-400/20';
        resultEl.textContent = 'Verification failed. Please try again.';
      }

      btn.textContent = 'Verify Chain';
      btn.disabled = false;
    });

    // Mint Block button
    document.getElementById('mint-block-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('mint-block-btn') as HTMLButtonElement;
      btn.textContent = 'Minting...';
      btn.disabled = true;

      try {
        const res = await fetch('/api/chain/mint', { method: 'POST' });
        const data = await res.json();

        if (data.error) {
          alert(data.error);
        } else if (data.block) {
          alert(`Block #${data.block.block_number} minted with ${data.block.entries_count} entries!`);
          window.location.reload();
        } else {
          alert(data.message || 'No pending entries to mint.');
        }
      } catch (e) {
        alert('Minting failed. Please try again.');
      }

      btn.textContent = 'Mint Block';
      btn.disabled = false;
    });

    // Block detail panel
    function attachBlockHandlers() {
      document.querySelectorAll('.block-row, .block-card').forEach((el) => {
        el.addEventListener('click', async () => {
          const blockNum = (el as HTMLElement).dataset.block;
          if (blockNum === undefined) return;

          const panel = document.getElementById('block-detail')!;
          panel.classList.remove('hidden');

          try {
            const res = await fetch(`/api/chain/blocks/${blockNum}`);
            const data = await res.json();
            const block = data.block;
            const entries = data.entries || [];

            document.getElementById('detail-block-num')!.textContent = String(block.block_number);
            document.getElementById('detail-block-time')!.textContent = block.timestamp;
            document.getElementById('detail-block-entries')!.textContent = `${block.entries_count} entries`;
            document.getElementById('detail-block-signer')!.textContent = block.signer_did;
            document.getElementById('detail-block-range')!.textContent =
              block.entries_count > 0 ? `#${block.entry_range_start} - #${block.entry_range_end}` : 'N/A (genesis)';
            document.getElementById('detail-block-hash')!.textContent = block.block_hash;
            document.getElementById('detail-block-prev')!.textContent = block.previous_block_hash;
            document.getElementById('detail-block-merkle')!.textContent = block.merkle_root;
            document.getElementById('detail-block-sig')!.textContent = block.signature || 'N/A';

            const listEl = document.getElementById('detail-block-entry-list')!;
            if (entries.length === 0) {
              listEl.innerHTML = '<div class="text-xs text-gray-600">No entries (genesis block).</div>';
            } else {
              listEl.innerHTML = entries.map((e: any) => `
                <div class="flex items-center gap-3 rounded-lg bg-navy-800 px-3 py-2">
                  <span class="text-xs font-mono text-white">#${e.sequence_number}</span>
                  <span class="text-xs font-medium px-2 py-0.5 rounded border inline-block ${getActionColor(e.action)}">
                    ${(e.action || '').replace(':', ' ').toUpperCase()}
                  </span>
                  <span class="text-xs text-gray-500">${e.target_type}/${e.target_id}</span>
                  <span class="text-xs font-mono text-gray-600 ml-auto" title="${e.payload_hash}">${truncHash(e.payload_hash, 8)}</span>
                </div>
              `).join('');
            }
          } catch (e) {
            panel.classList.add('hidden');
          }
        });
      });
    }

    // Close detail
    document.getElementById('close-block-detail')?.addEventListener('click', () => {
      document.getElementById('block-detail')!.classList.add('hidden');
    });
    document.getElementById('block-detail')?.addEventListener('click', (e) => {
      if (e.target === document.getElementById('block-detail')) {
        document.getElementById('block-detail')!.classList.add('hidden');
      }
    });

    attachBlockHandlers();
  </script>
</MarketingLayout>
