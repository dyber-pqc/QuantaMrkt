---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { getModelBySlug } from '../../lib/db';

const { slug } = Astro.params;
const db = (Astro.locals as any).runtime?.env?.DB;
const model = db ? await getModelBySlug(db, slug!) : null;
if (!model) return Astro.redirect('/models');

const tags: string[] = (() => {
  try { return JSON.parse(model.tags || '[]'); } catch { return []; }
})();

const riskLevel = model.hndl?.risk_level || '';
const riskScore = model.hndl?.risk_score ?? 0;
const shelfLife = model.hndl?.shelf_life_years ? `${model.hndl.shelf_life_years} years` : 'N/A';
const recommendation = model.hndl?.recommendation || '';
const algorithm = model.signatures?.[0]?.algorithm || '';

function riskBadgeClass(level: string): string {
  switch (level.toUpperCase()) {
    case 'CRITICAL': return 'badge-critical';
    case 'HIGH': return 'badge-high';
    case 'MEDIUM': return 'badge-medium';
    default: return 'badge-low';
  }
}

function formatSize(bytes: number): string {
  if (bytes >= 1_000_000_000) return (bytes / 1_000_000_000).toFixed(1) + ' GB';
  if (bytes >= 1_000_000) return (bytes / 1_000_000).toFixed(1) + ' MB';
  if (bytes >= 1_000) return (bytes / 1_000).toFixed(1) + ' KB';
  return bytes + ' B';
}

function sigRoleLabel(type: string | null): string {
  switch (type) {
    case 'creator': return 'Creator';
    case 'auditor': return 'Auditor';
    case 'registry': return 'Registry';
    default: return type || 'Signer';
  }
}
---

<MarketingLayout title={`${model.author}/${model.name}`} description={model.description || ''}>
  <div class="mx-auto max-w-7xl px-6 py-8">
    <!-- Back link -->
    <a href="/models" class="inline-flex items-center gap-1 text-xs text-gray-500 hover:text-gray-300 transition-colors mb-4">
      <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      Back to Models
    </a>

    <!-- PQC Verification Banner -->
    {model.verified ? (
      <div class="rounded-xl border border-quantum/20 bg-quantum/[0.04] px-5 py-4 mb-6">
        <div class="flex items-start gap-3">
          <svg class="h-6 w-6 text-quantum flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.352.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <div>
            <p class="text-sm font-semibold text-quantum mb-1">PQC-Verified{algorithm ? ` with ${algorithm}` : ''}</p>
            <p class="text-xs text-gray-400">All file hashes match the source. Signature chain includes {model.signatures.length} verification(s). Verified on {model.updated_at?.slice(0, 10) || 'N/A'}.</p>
            <a href="#signatures" class="text-xs text-quantum/80 hover:text-quantum mt-1 inline-block">View transparency log</a>
          </div>
        </div>
      </div>
    ) : (
      <div class="rounded-xl border border-warning/20 bg-warning/[0.04] px-5 py-4 mb-6">
        <div class="flex items-start gap-3">
          <svg class="h-6 w-6 text-warning flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          <div>
            <p class="text-sm font-semibold text-warning mb-1">Unverified Model</p>
            <p class="text-xs text-gray-400">This model has not been PQC-verified. File integrity cannot be guaranteed against quantum threats.</p>
          </div>
        </div>
      </div>
    )}

    <!-- Model Header -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mb-8">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 text-sm font-bold text-gray-400">
            {model.author?.[0]?.toUpperCase() || '?'}
          </div>
          <div>
            <h1 class="text-xl font-bold text-white">{model.author}<span class="text-gray-500">/</span>{model.name}</h1>
            <p class="text-xs text-gray-500">{model.author}</p>
          </div>
        </div>
        <p class="text-sm text-gray-400 max-w-2xl mb-3">{model.description}</p>
        <div class="flex items-center gap-2 flex-wrap">
          {tags.map((tag) => (
            <span class="inline-flex rounded-md bg-white/5 px-2 py-0.5 text-[11px] text-gray-500">{tag}</span>
          ))}
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1 text-xs text-gray-500">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          {(model.downloads ?? 0).toLocaleString()}
        </span>
        <span class="inline-flex items-center gap-1 text-xs text-gray-500">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
          {(model.likes ?? 0).toLocaleString()}
        </span>
      </div>
    </div>

    <!-- Tab Headers (visual only) -->
    <div class="flex items-center gap-1 border-b border-white/5 mb-6">
      <button class="px-4 py-2 text-xs font-medium text-electric border-b-2 border-electric">Model Card</button>
      <a href="#files" class="px-4 py-2 text-xs font-medium text-gray-500 hover:text-gray-300 transition-colors">Files</a>
      <a href="#signatures" class="px-4 py-2 text-xs font-medium text-gray-500 hover:text-gray-300 transition-colors">Signatures</a>
      <a href="#hndl" class="px-4 py-2 text-xs font-medium text-gray-500 hover:text-gray-300 transition-colors">HNDL Risk</a>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
      <!-- Main Content -->
      <div class="lg:col-span-3 space-y-6">
        <!-- Model Card -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-5 py-3 border-b border-white/5">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Model Card</h2>
          </div>
          <div class="px-5 py-4 prose prose-invert prose-sm max-w-none text-gray-300">
            <div class="space-y-3 text-xs leading-relaxed">
              <p class="text-gray-400">{model.description || 'No model card available.'}</p>
              {model.framework && (
                <p class="text-gray-500"><span class="text-gray-400">Framework:</span> {model.framework}</p>
              )}
              {model.parameters && (
                <p class="text-gray-500"><span class="text-gray-400">Parameters:</span> {model.parameters}</p>
              )}
            </div>
          </div>
        </div>

        <!-- Files -->
        <div id="files" class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-5 py-3 border-b border-white/5 flex items-center justify-between">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">File Manifest</h2>
            <span class="text-xs text-gray-600">{model.files.length} files &middot; SHA3-256</span>
          </div>
          {model.files.length > 0 ? (
            <table class="w-full text-xs">
              <thead>
                <tr class="border-b border-white/5 text-gray-500">
                  <th class="text-left font-medium px-5 py-2">Filename</th>
                  <th class="text-left font-medium px-5 py-2 hidden md:table-cell">SHA3-256</th>
                  <th class="text-right font-medium px-5 py-2">Size</th>
                </tr>
              </thead>
              <tbody>
                {model.files.map((file: any, i: number) => (
                  <tr class={`border-b border-white/[0.03] ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`}>
                    <td class="px-5 py-2">
                      <span class="font-mono text-gray-300">{file.filename}</span>
                    </td>
                    <td class="px-5 py-2 hidden md:table-cell">
                      <span class="font-mono text-gray-600 text-[10px]">{(file.sha3_256_hash || '').slice(0, 24)}...</span>
                    </td>
                    <td class="px-5 py-2 text-right">
                      <span class="text-gray-500 whitespace-nowrap">{formatSize(file.size)}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <div class="px-5 py-8 text-center text-xs text-gray-600">No files in manifest.</div>
          )}
        </div>

        <!-- Signatures -->
        <div id="signatures" class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-5 py-3 border-b border-white/5">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Signature Chain</h2>
          </div>
          <div class="p-5">
            {model.signatures.length > 0 ? (
              model.signatures.map((sig: any, i: number) => (
                <div class="flex items-start gap-3">
                  <div class="flex flex-col items-center">
                    <div class={`flex h-6 w-6 items-center justify-center rounded-full text-[10px] font-bold ${
                      i === 0 ? 'bg-electric/15 text-electric' :
                      i === 1 ? 'bg-warning/15 text-warning' :
                      'bg-quantum/15 text-quantum'
                    }`}>
                      {i + 1}
                    </div>
                    {i < model.signatures.length - 1 && (
                      <div class="w-px h-10 bg-white/10 my-1" />
                    )}
                  </div>
                  <div class={`flex-1 ${i < model.signatures.length - 1 ? 'pb-4' : ''}`}>
                    <div class="flex items-center gap-2 mb-0.5">
                      <span class="text-xs font-semibold text-gray-200">{sigRoleLabel(sig.attestation_type)}</span>
                      <span class="font-mono text-[11px] text-gray-500">{sig.algorithm}</span>
                      <span class="text-[11px] text-gray-600">{sig.signed_at ? new Date(sig.signed_at).toLocaleString() : ''}</span>
                    </div>
                    <p class="font-mono text-[11px] text-gray-500">{sig.signer_did}</p>
                    <p class="text-[11px] text-gray-600 mt-0.5">Signature: <span class="font-mono">{(sig.signature_hex || '').slice(0, 20)}...</span></p>
                  </div>
                </div>
              ))
            ) : (
              <p class="text-xs text-gray-600 text-center py-4">No signatures recorded.</p>
            )}
          </div>
        </div>

        <!-- HNDL Risk -->
        <div id="hndl" class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-5 py-3 border-b border-white/5">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">HNDL Risk Assessment</h2>
          </div>
          <div class="p-5">
            {model.hndl ? (
              <>
                <div class="flex items-center gap-6 mb-4">
                  {/* Score gauge */}
                  <div class="relative h-24 w-24 flex-shrink-0">
                    <svg class="h-24 w-24 -rotate-90" viewBox="0 0 96 96">
                      <circle cx="48" cy="48" r="40" fill="none" stroke="currentColor" stroke-width="6" class="text-white/5" />
                      <circle cx="48" cy="48" r="40" fill="none" stroke="currentColor" stroke-width="6"
                        stroke-dasharray={`${(riskScore / 100) * 251.3} 251.3`}
                        class="text-danger" stroke-linecap="round" />
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                      <span class="text-2xl font-bold text-white font-mono">{Math.round(riskScore)}</span>
                      <span class="text-[10px] text-gray-500">/ 100</span>
                    </div>
                  </div>
                  <div class="space-y-2 text-xs">
                    <div class="flex items-center justify-between gap-8">
                      <span class="text-gray-500">Risk Level</span>
                      <span class={riskBadgeClass(riskLevel)}>{riskLevel}</span>
                    </div>
                    <div class="flex items-center justify-between gap-8">
                      <span class="text-gray-500">Quantum Shelf Life</span>
                      <span class="font-mono text-gray-300">{shelfLife}</span>
                    </div>
                    <div class="flex items-center justify-between gap-8">
                      <span class="text-gray-500">PQC Status</span>
                      <span class={`text-xs ${model.verified ? 'text-quantum' : 'text-gray-500'}`}>{model.verified ? 'Verified' : 'Unverified'}</span>
                    </div>
                  </div>
                </div>
                {recommendation && (
                  <div class="rounded-lg border border-warning/10 bg-warning/[0.03] p-4">
                    <h3 class="text-xs font-semibold text-warning mb-1">Advisory</h3>
                    <p class="text-xs text-gray-400 leading-relaxed">{recommendation}</p>
                  </div>
                )}
              </>
            ) : (
              <p class="text-xs text-gray-600 text-center py-4">No HNDL assessment available for this model.</p>
            )}
          </div>
        </div>
      </div>

      <!-- Right Sidebar -->
      <div class="space-y-5">
        <!-- Download -->
        <div class="rounded-xl border border-white/5 bg-navy-800 p-4">
          <button class="w-full rounded-lg bg-electric text-navy-900 font-semibold text-sm py-2.5 hover:bg-electric-400 transition-colors mb-3">
            Download Model
          </button>
          <div class="rounded-lg bg-navy-900 border border-white/5 p-3 mb-3">
            <p class="text-[10px] text-gray-500 uppercase tracking-wider font-medium mb-1.5">Verify Locally</p>
            <code class="text-[11px] font-mono text-gray-400 break-all">quantumshield registry verify {model.author}/{model.name}</code>
          </div>
          <button class="w-full rounded-lg border border-white/10 bg-white/5 text-sm text-gray-300 py-2 hover:bg-white/10 hover:text-white transition-colors">
            Clone Repository
          </button>
        </div>

        <!-- Metadata -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-4 py-2.5 border-b border-white/5">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Model Info</h3>
          </div>
          <div class="divide-y divide-white/[0.03]">
            {model.license && (
              <div class="flex items-center justify-between px-4 py-2.5">
                <span class="text-[11px] text-gray-500">License</span>
                <span class="text-[11px] text-gray-300 text-right max-w-[140px] truncate">{model.license}</span>
              </div>
            )}
            {model.framework && (
              <div class="flex items-center justify-between px-4 py-2.5">
                <span class="text-[11px] text-gray-500">Framework</span>
                <span class="text-[11px] text-gray-300">{model.framework}</span>
              </div>
            )}
            {model.parameters && (
              <div class="flex items-center justify-between px-4 py-2.5">
                <span class="text-[11px] text-gray-500">Parameters</span>
                <span class="font-mono text-[11px] text-gray-300">{model.parameters}</span>
              </div>
            )}
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-[11px] text-gray-500">Created</span>
              <span class="text-[11px] text-gray-300">{model.created_at?.slice(0, 10) || 'N/A'}</span>
            </div>
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-[11px] text-gray-500">Downloads</span>
              <span class="font-mono text-[11px] text-gray-300">{(model.downloads ?? 0).toLocaleString()}</span>
            </div>
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-[11px] text-gray-500">Likes</span>
              <span class="font-mono text-[11px] text-gray-300">{(model.likes ?? 0).toLocaleString()}</span>
            </div>
          </div>
        </div>

        <!-- Tags -->
        <div class="rounded-xl border border-white/5 bg-navy-800 p-4">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Tags</h3>
          <div class="flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <span class="inline-flex rounded-md bg-white/5 px-2 py-0.5 text-[11px] text-gray-500 hover:bg-white/10 hover:text-gray-300 transition-colors cursor-pointer">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</MarketingLayout>
