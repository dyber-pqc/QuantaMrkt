            <div class="divide-y divide-white/[0.03]">
              {model.license && (
                <div class="flex items-center justify-between py-2">
                  <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
                    License
                  </span>
                  <span class="text-[11px] text-gray-300 font-medium">{model.license}</span>
                </div>
              )}
              {model.framework && (
                <div class="flex items-center justify-between py-2">
                  <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
                    Framework
                  </span>
                  <span class="text-[11px] text-gray-300">{model.framework}</span>
                </div>
              )}
              {model.parameters && (
                <div class="flex items-center justify-between py-2">
                  <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
                    Parameters
                  </span>
                  <span class="text-[11px] text-gray-300 font-mono">{model.parameters}</span>
                </div>
              )}
              <div class="flex items-center justify-between py-2">
                <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
                  <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                  Created
                </span>
                <span class="text-[11px] text-gray-300">{model.created_at?.slice(0, 10) || 'N/A'}</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
                  <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                  Downloads
                </span>
                <span class="text-[11px] text-gray-300 font-mono">{(model.downloads ?? 0).toLocaleString()}</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
                  <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                  Likes
                </span>
                <span class="text-[11px] text-gray-300 font-mono">{(model.likes ?? 0).toLocaleString()}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Get this model -->
        <div class="rounded-xl border border-electric/20 bg-navy-800 overflow-hidden">
          <div class="px-4 py-3 border-b border-electric/10 bg-electric/[0.03]">
            <h3 class="text-xs font-semibold text-electric uppercase tracking-wider">Get this model</h3>
          </div>
          <div class="p-4 space-y-2.5">
            {model.source_url && model.hf_repo_id && (
              <a href={model.source_url} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full rounded-lg bg-yellow-500/10 border border-yellow-500/20 text-xs font-medium text-yellow-400 px-4 py-2.5 hover:bg-yellow-500/20 transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                View on HuggingFace
              </a>
            )}
            {model.ollama_name && (
              <div class="rounded-lg bg-navy-900 border border-white/5 p-3 relative group">
                <p class="text-[10px] text-gray-500 uppercase tracking-wider font-medium mb-1">Pull with Ollama</p>
                <code class="text-[11px] font-mono text-gray-300 break-all">ollama pull {model.ollama_name}</code>
                <button data-copy={`ollama pull ${model.ollama_name}`} class="absolute top-2 right-2 rounded border border-white/10 bg-white/5 px-1.5 py-0.5 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors opacity-0 group-hover:opacity-100">Copy</button>
              </div>
            )}
            <div class="rounded-lg bg-navy-900 border border-white/5 p-3 relative group">
              <p class="text-[10px] text-gray-500 uppercase tracking-wider font-medium mb-1">Pull with QuantumShield</p>
              <code class="text-[11px] font-mono text-electric break-all">quantumshield pull {model.author}/{model.name}</code>
              <button data-copy={`quantumshield pull ${model.author}/${model.name}`} class="absolute top-2 right-2 rounded border border-white/10 bg-white/5 px-1.5 py-0.5 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors opacity-0 group-hover:opacity-100">Copy</button>
            </div>
            <div class="rounded-lg bg-navy-900 border border-white/5 p-3 relative group">
              <p class="text-[10px] text-gray-500 uppercase tracking-wider font-medium mb-1">Verify signatures</p>
              <code class="text-[11px] font-mono text-quantum break-all">quantumshield verify {model.author}/{model.name}</code>
              <button data-copy={`quantumshield verify ${model.author}/${model.name}`} class="absolute top-2 right-2 rounded border border-white/10 bg-white/5 px-1.5 py-0.5 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors opacity-0 group-hover:opacity-100">Copy</button>
            </div>
          </div>
        </div>

        <!-- Links -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-4 py-3 border-b border-white/5">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Links</h3>
          </div>
          <div class="p-4 space-y-2">
            {model.source_url && (
              <a href={model.source_url} target="_blank" rel="noopener" class="flex items-center gap-2 text-xs text-gray-400 hover:text-white transition-colors">
                <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                {model.hf_repo_id ? `huggingface.co/${model.hf_repo_id}` : 'Source Repository'}
              </a>
            )}
            <a href={`/transparency?target_id=${model.slug}&target_type=model`} class="flex items-center gap-2 text-xs text-gray-400 hover:text-white transition-colors">
              <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
              Transparency Log
            </a>
            <a href={`/api/models/${model.slug}`} target="_blank" class="flex items-center gap-2 text-xs text-gray-400 hover:text-white transition-colors">
              <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
              API Endpoint
            </a>
          </div>
        </div>

        <!-- Signers -->
        {uniqueSigners.length > 0 && (
          <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
            <div class="px-4 py-3 border-b border-white/5">
              <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Signers</h3>
            </div>
            <div class="p-4 space-y-2">
              {uniqueSigners.map((did: string) => (
                <div class="flex items-center gap-2">
                  <div class="flex h-6 w-6 items-center justify-center rounded-full bg-electric/10 text-electric text-[10px] font-bold flex-shrink-0">
                    {did.slice(-2).toUpperCase()}
                  </div>
                  <span class="font-mono text-[10px] text-gray-500 truncate" title={did}>{did.length > 30 ? did.slice(0, 20) + '...' + did.slice(-8) : did}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="rounded-xl border border-white/5 bg-navy-800 p-4">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Tags</h3>
            <div class="flex flex-wrap gap-1.5">
              {tags.map((tag) => (
                <a href={`/models?q=${tag}`} class="inline-flex rounded-full bg-white/5 px-2.5 py-0.5 text-[11px] text-gray-500 hover:bg-white/10 hover:text-gray-300 transition-colors">{tag}</a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

<script define:vars={{ slug: model.slug }}>
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      // Update buttons
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('text-electric', 'border-electric');
        b.classList.add('text-gray-500', 'border-transparent');
      });
      btn.classList.remove('text-gray-500', 'border-transparent');
      btn.classList.add('text-electric', 'border-electric');
      // Update panels
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
      const panel = document.getElementById('tab-' + tab);
      if (panel) panel.classList.remove('hidden');
      // Update URL hash
      window.location.hash = tab;
    });
  });

  // Restore tab from hash
  const hash = window.location.hash.slice(1);
  if (hash) {
    const btn = document.querySelector(`.tab-btn[data-tab="${hash}"]`);
    if (btn) btn.click();
  }

  // Copy-to-clipboard buttons
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const text = btn.dataset.copy || '';
      await navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig || ''; }, 1500);
    });
  });

  // Use Model modal
  const useBtn = document.getElementById('use-model-btn');
  const modal = document.getElementById('use-model-modal');
  const closeBtn = document.getElementById('close-modal-btn');
  if (useBtn && modal && closeBtn) {
    useBtn.addEventListener('click', () => modal.classList.remove('hidden'));
    closeBtn.addEventListener('click', () => modal.classList.add('hidden'));
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });
  }

  // Verify Signature button
  const verifyBtn = document.getElementById('verify-btn');
  const verifyResult = document.getElementById('verify-result');
  if (verifyBtn && verifyResult) {
    verifyBtn.addEventListener('click', async () => {
      verifyBtn.textContent = 'Verifying...';
      verifyBtn.disabled = true;
      try {
        const res = await fetch(`/api/models/${slug}/verify`);
        const data = await res.json();
        verifyResult.classList.remove('hidden');
        if (data.verified) {
          const fi = data.file_integrity || {};
          const sigCount = (data.signatures || []).length;
          const algo = data.signatures?.[0]?.algorithm || 'PQC';
          const sourceLabel = fi.source_checked ? `Source: ${fi.source}` : 'Local verification only';

          let integrityHtml = '';
          if (fi.total_files > 0) {
            const allMatched = fi.mismatched === 0 && fi.missing === 0;
            const barColor = allMatched ? 'bg-emerald-500' : 'bg-yellow-500';
            const matchPct = fi.total_files > 0 ? Math.round((fi.matched / fi.total_files) * 100) : 0;
            integrityHtml = `
              <div class="mt-3 pt-3 border-t border-emerald-500/10">
                <div class="flex items-center justify-between mb-1.5">
                  <span class="text-[11px] text-emerald-400/80 font-medium">File Integrity</span>
                  <span class="text-[10px] text-emerald-400/60">${sourceLabel}</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="flex-1 h-1.5 rounded-full bg-white/5 overflow-hidden">
                    <div class="${barColor} h-full rounded-full transition-all" style="width: ${matchPct}%"></div>
                  </div>
                  <span class="text-[11px] font-mono text-emerald-400">${fi.matched}/${fi.total_files}</span>
                </div>
                <div class="flex gap-4 mt-2 text-[10px]">
                  <span class="text-emerald-400/70">${fi.matched} matched</span>
                  ${fi.mismatched > 0 ? `<span class="text-yellow-400">${fi.mismatched} mismatched</span>` : ''}
                  ${fi.missing > 0 ? `<span class="text-red-400">${fi.missing} missing</span>` : ''}
                </div>
              </div>
            `;
          }

          verifyResult.className = 'rounded-xl border border-emerald-500/20 bg-emerald-500/[0.06] px-5 py-4 mb-5 text-sm text-emerald-400';
          verifyResult.innerHTML = `
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div class="flex-1">
                <strong>Signature verified.</strong> ${sigCount} ${algo} signature(s) valid.
                ${integrityHtml}
                <p class="text-[10px] text-emerald-400/50 mt-2">Checked at ${new Date(data.checked_at).toLocaleString()}</p>
              </div>
            </div>
          `;
        } else {
          verifyResult.className = 'rounded-xl border border-yellow-500/20 bg-yellow-500/[0.06] px-5 py-4 mb-5 text-sm text-yellow-400';
          verifyResult.innerHTML = `
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
              <div>
                <strong>No signatures found.</strong> This model has not been signed yet.
                <p class="text-[10px] text-yellow-400/70 mt-1">Submit this model to generate PQC signatures.</p>
              </div>
            </div>
          `;
        }
      } catch {
        verifyResult.classList.remove('hidden');
        verifyResult.className = 'rounded-xl border border-red-500/20 bg-red-500/[0.06] px-5 py-4 mb-5 text-sm text-red-400';
        verifyResult.textContent = 'Error contacting verification API.';
      }
      verifyBtn.textContent = 'Verify';
      verifyBtn.disabled = false;
    });
  }

  // Load activity log
  async function loadActivity() {
    const container = document.getElementById('activity-list');
    if (!container) return;
    try {
      const res = await fetch(`/api/transparency/${slug}`);
      if (!res.ok) throw new Error('Failed to fetch');
      const data = await res.json();
      const entries = data.entries || data || [];
      if (entries.length === 0) {
        container.innerHTML = '<div class="text-center py-8"><p class="text-xs text-gray-600">No activity recorded for this model.</p></div>';
        return;
      }
      container.innerHTML = entries.slice(0, 20).map((entry, i) => `
        <div class="flex items-start gap-3 ${i > 0 ? 'mt-3 pt-3 border-t border-white/5' : ''}">
          <div class="flex h-6 w-6 items-center justify-center rounded-full bg-electric/10 text-electric text-[10px] flex-shrink-0 mt-0.5">
            ${i + 1}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-gray-300">${entry.action || entry.event || 'Activity'}</p>
            <p class="text-[10px] text-gray-600 mt-0.5">${entry.details || entry.target || ''}</p>
            <p class="text-[10px] text-gray-600 mt-0.5">${entry.created_at || entry.timestamp || ''}</p>
          </div>
        </div>
      `).join('');
    } catch {
      container.innerHTML = '<div class="text-center py-8"><p class="text-xs text-gray-600">Unable to load activity log.</p></div>';
    }
  }

  // Load activity when tab is clicked
  const activityBtn = document.querySelector('.tab-btn[data-tab="activity"]');
  if (activityBtn) {
    let loaded = false;
    activityBtn.addEventListener('click', () => { if (!loaded) { loaded = true; loadActivity(); } });
  }
</script>
</MarketingLayout>
