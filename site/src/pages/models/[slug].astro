---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { getModelBySlug } from '../../lib/db';

const { slug } = Astro.params;
const db = (Astro.locals as any).runtime?.env?.DB;
const model = db ? await getModelBySlug(db, slug!) : null;
if (!model) return Astro.redirect('/models');

const tags: string[] = (() => {
  try { return JSON.parse(model.tags || '[]'); } catch { return []; }
})();

const riskLevel = model.hndl?.risk_level || '';
const riskScore = model.hndl?.risk_score ?? 0;
const shelfLife = model.hndl?.shelf_life_years ? `${model.hndl.shelf_life_years} years` : 'N/A';
const recommendation = model.hndl?.recommendation || '';
const algorithm = model.signatures?.[0]?.algorithm || '';

function riskBadgeClass(level: string): string {
  switch (level.toUpperCase()) {
    case 'CRITICAL': return 'text-red-400 bg-red-500/10 border-red-500/20';
    case 'HIGH': return 'text-orange-400 bg-orange-500/10 border-orange-500/20';
    case 'MEDIUM': return 'text-yellow-400 bg-yellow-500/10 border-yellow-500/20';
    default: return 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20';
  }
}

function riskGaugeColor(level: string): string {
  switch (level.toUpperCase()) {
    case 'CRITICAL': return 'text-red-500';
    case 'HIGH': return 'text-orange-500';
    case 'MEDIUM': return 'text-yellow-500';
    default: return 'text-emerald-500';
  }
}

function formatSize(bytes: number): string {
  if (bytes >= 1_000_000_000) return (bytes / 1_000_000_000).toFixed(1) + ' GB';
  if (bytes >= 1_000_000) return (bytes / 1_000_000).toFixed(1) + ' MB';
  if (bytes >= 1_000) return (bytes / 1_000).toFixed(1) + ' KB';
  return bytes + ' B';
}

function sigRoleLabel(type: string | null): string {
  switch (type) {
    case 'creator': return 'Creator';
    case 'auditor': return 'Auditor';
    case 'registry': return 'Registry';
    default: return type || 'Signer';
  }
}

function sigRoleIcon(type: string | null): string {
  switch (type) {
    case 'creator': return 'text-electric bg-electric/10';
    case 'auditor': return 'text-yellow-400 bg-yellow-400/10';
    case 'registry': return 'text-quantum bg-quantum/10';
    default: return 'text-gray-400 bg-white/5';
  }
}

// Build file tree structure
interface FileNode {
  name: string;
  path: string;
  size: number;
  hash: string;
  isDir: boolean;
  children: FileNode[];
  depth: number;
}

function buildFileTree(files: any[]): FileNode[] {
  const root: FileNode[] = [];
  const dirs = new Map<string, FileNode>();

  for (const file of files) {
    const parts = file.filename.split('/');
    let currentLevel = root;

    for (let i = 0; i < parts.length - 1; i++) {
      const dirPath = parts.slice(0, i + 1).join('/');
      if (!dirs.has(dirPath)) {
        const dirNode: FileNode = {
          name: parts[i],
          path: dirPath,
          size: 0,
          hash: '',
          isDir: true,
          children: [],
          depth: i,
        };
        dirs.set(dirPath, dirNode);
        currentLevel.push(dirNode);
      }
      currentLevel = dirs.get(dirPath)!.children;
    }

    currentLevel.push({
      name: parts[parts.length - 1],
      path: file.filename,
      size: file.size,
      hash: file.sha3_256_hash || '',
      isDir: false,
      children: [],
      depth: parts.length - 1,
    });
  }

  return root;
}

function flattenTree(nodes: FileNode[], depth: number = 0): FileNode[] {
  const result: FileNode[] = [];
  // Sort: directories first, then files alphabetically
  const sorted = [...nodes].sort((a, b) => {
    if (a.isDir && !b.isDir) return -1;
    if (!a.isDir && b.isDir) return 1;
    return a.name.localeCompare(b.name);
  });
  for (const node of sorted) {
    result.push({ ...node, depth });
    if (node.isDir) {
      result.push(...flattenTree(node.children, depth + 1));
    }
  }
  return result;
}

const fileTree = flattenTree(buildFileTree(model.files));
const totalSize = model.files.reduce((s: number, f: any) => s + (f.size || 0), 0);
const uniqueSigners = [...new Set(model.signatures.map((s: any) => s.signer_did))];
---

<MarketingLayout title={`${model.author}/${model.name}`} description={model.description || ''}>
  <div class="mx-auto max-w-7xl px-6 py-6">

    <!-- Breadcrumb / Back -->
    <nav class="flex items-center gap-2 text-xs text-gray-500 mb-5">
      <a href="/models" class="hover:text-gray-300 transition-colors">Models</a>
      <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      <span class="text-gray-400">{model.author}</span>
      <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      <span class="text-gray-300">{model.name}</span>
    </nav>

    <!-- Repository Header -->
    <div class="rounded-xl border border-white/5 bg-navy-800 p-5 mb-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex items-start gap-4">
          <!-- Author avatar -->
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-electric/20 to-quantum/20 text-lg font-bold text-gray-300 flex-shrink-0">
            {model.author?.[0]?.toUpperCase() || '?'}
          </div>
          <div>
            <div class="flex items-center gap-2 flex-wrap">
              <h1 class="text-xl font-bold text-white">
                <a href={`/models?q=${model.author}`} class="text-electric hover:underline">{model.author}</a>
                <span class="text-gray-600 mx-0.5">/</span>
                <span>{model.name}</span>
              </h1>
              {model.verified ? (
                <span class="inline-flex items-center gap-1 rounded-full bg-quantum/10 border border-quantum/20 px-2.5 py-0.5 text-[11px] font-medium text-quantum">
                  <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.352.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  PQC Verified
                </span>
              ) : (
                <span class="inline-flex items-center gap-1 rounded-full bg-yellow-500/10 border border-yellow-500/20 px-2.5 py-0.5 text-[11px] font-medium text-yellow-400">
                  Unverified
                </span>
              )}
              {model.source_platform === 'huggingface' && (
                <span class="inline-flex items-center gap-1 rounded-full bg-yellow-500/10 border border-yellow-500/20 px-2.5 py-0.5 text-[11px] font-medium text-yellow-400">HuggingFace</span>
              )}
              {model.ollama_name && (
                <span class="inline-flex items-center gap-1 rounded-full bg-white/5 border border-white/10 px-2.5 py-0.5 text-[11px] font-medium text-gray-400">Ollama</span>
              )}
              {riskLevel && (
                <span class={`inline-flex items-center rounded-full border px-2.5 py-0.5 text-[11px] font-medium ${riskBadgeClass(riskLevel)}`}>
                  HNDL: {riskLevel}
                </span>
              )}
            </div>
            <p class="text-sm text-gray-400 mt-1.5 max-w-2xl">{model.description}</p>
            <!-- Tags -->
            <div class="flex items-center gap-1.5 flex-wrap mt-3">
              {tags.map((tag) => (
                <a href={`/models?q=${tag}`} class="inline-flex rounded-full bg-white/5 border border-white/5 px-2.5 py-0.5 text-[11px] text-gray-400 hover:bg-white/10 hover:text-gray-200 transition-colors">{tag}</a>
              ))}
            </div>
          </div>
        </div>

        <!-- Stats & Actions -->
        <div class="flex flex-col items-end gap-3 flex-shrink-0">
          <div class="flex items-center gap-4">
            <span class="inline-flex items-center gap-1.5 text-xs text-gray-400">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
              <span class="font-mono font-medium">{(model.likes ?? 0).toLocaleString()}</span>
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs text-gray-400">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              <span class="font-mono font-medium">{(model.downloads ?? 0).toLocaleString()}</span>
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs text-gray-400">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              <span class="font-mono font-medium">{model.signatures.length}</span>
            </span>
          </div>
          <div class="flex items-center gap-2">
            <button id="use-model-btn" class="rounded-lg bg-electric text-navy-900 font-semibold text-xs px-4 py-2 hover:bg-electric/90 transition-colors">
              Use Model
            </button>
            <button id="verify-btn" data-slug={model.slug} class="rounded-lg border border-quantum/30 bg-quantum/10 text-xs text-quantum px-4 py-2 hover:bg-quantum/20 transition-colors font-medium">
              Verify
            </button>
            <button class="rounded-lg border border-white/10 bg-white/5 text-xs text-gray-400 px-3 py-2 hover:bg-white/10 hover:text-white transition-colors" title="Report Issue">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Use Model Modal (hidden by default) -->
    <div id="use-model-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
      <div class="rounded-xl border border-white/10 bg-navy-800 p-6 max-w-md w-full mx-4 shadow-2xl">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-white">Use this model</h3>
          <button id="close-modal-btn" class="text-gray-500 hover:text-white transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <div class="space-y-3">
          {model.source_url && model.hf_repo_id && (
            <a href={model.source_url} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full rounded-lg bg-yellow-500/10 border border-yellow-500/20 text-xs font-medium text-yellow-400 px-4 py-2.5 hover:bg-yellow-500/20 transition-colors">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              View on HuggingFace
            </a>
          )}
          {model.ollama_name && (
            <div class="rounded-lg bg-navy-900 border border-white/5 p-3 group relative">
              <p class="text-[10px] text-gray-500 uppercase tracking-wider font-medium mb-1.5">Pull with Ollama</p>
              <code class="text-xs font-mono text-gray-300 break-all">ollama pull {model.ollama_name}</code>
              <button data-copy={`ollama pull ${model.ollama_name}`} class="absolute top-2 right-2 rounded border border-white/10 bg-white/5 px-1.5 py-1 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors opacity-0 group-hover:opacity-100">Copy</button>
            </div>
          )}
          <div class="rounded-lg bg-navy-900 border border-white/5 p-3 group relative">
            <p class="text-[10px] text-gray-500 uppercase tracking-wider font-medium mb-1.5">Pull with QuantumShield</p>
            <code class="text-xs font-mono text-electric break-all">quantumshield pull {model.author}/{model.name}</code>
            <button data-copy={`quantumshield pull ${model.author}/${model.name}`} class="absolute top-2 right-2 rounded border border-white/10 bg-white/5 px-1.5 py-1 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors opacity-0 group-hover:opacity-100">Copy</button>
          </div>
          <div class="rounded-lg bg-navy-900 border border-white/5 p-3 group relative">
            <p class="text-[10px] text-gray-500 uppercase tracking-wider font-medium mb-1.5">Verify integrity</p>
            <code class="text-xs font-mono text-quantum break-all">quantumshield verify {model.author}/{model.name}</code>
            <button data-copy={`quantumshield verify ${model.author}/${model.name}`} class="absolute top-2 right-2 rounded border border-white/10 bg-white/5 px-1.5 py-1 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors opacity-0 group-hover:opacity-100">Copy</button>
          </div>
          <div class="rounded-lg bg-navy-900 border border-white/5 p-3 group relative">
            <p class="text-[10px] text-gray-500 uppercase tracking-wider font-medium mb-1.5">pip install</p>
            <code class="text-xs font-mono text-gray-400 break-all">pip install quantumshield && quantumshield pull {model.author}/{model.name}</code>
            <button data-copy={`pip install quantumshield && quantumshield pull ${model.author}/${model.name}`} class="absolute top-2 right-2 rounded border border-white/10 bg-white/5 px-1.5 py-1 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors opacity-0 group-hover:opacity-100">Copy</button>
          </div>
        </div>
        <a href="/download" class="block mt-4 text-center text-xs text-electric hover:underline">Don't have the CLI? Download it here</a>
      </div>
    </div>

    <!-- Verify Result Banner -->
    <div id="verify-result" class="hidden rounded-xl border px-5 py-4 mb-5 text-sm"></div>

    <!-- Tab Navigation -->
    <div class="flex items-center gap-1 border-b border-white/5 mb-6 overflow-x-auto" id="tab-nav">
      <button data-tab="overview" class="tab-btn active flex items-center gap-1.5 px-4 py-2.5 text-xs font-medium text-electric border-b-2 border-electric whitespace-nowrap transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
        Overview
      </button>
      <button data-tab="files" class="tab-btn flex items-center gap-1.5 px-4 py-2.5 text-xs font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-300 whitespace-nowrap transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
        Files
        <span class="rounded-full bg-white/5 px-1.5 py-0.5 text-[10px] text-gray-500">{model.files.length}</span>
      </button>
      <button data-tab="signatures" class="tab-btn flex items-center gap-1.5 px-4 py-2.5 text-xs font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-300 whitespace-nowrap transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        Signatures
        <span class="rounded-full bg-white/5 px-1.5 py-0.5 text-[10px] text-gray-500">{model.signatures.length}</span>
      </button>
      <button data-tab="hndl" class="tab-btn flex items-center gap-1.5 px-4 py-2.5 text-xs font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-300 whitespace-nowrap transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
        HNDL Risk
      </button>
      <button data-tab="activity" class="tab-btn flex items-center gap-1.5 px-4 py-2.5 text-xs font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-300 whitespace-nowrap transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        Activity
      </button>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
      <!-- Main Content -->
      <div class="lg:col-span-3 space-y-6">

        <!-- ===== OVERVIEW TAB ===== -->
        <div id="tab-overview" class="tab-panel space-y-6">
          <!-- PQC Verification Banner -->
          {model.verified ? (
            <div class="rounded-xl border border-quantum/20 bg-quantum/[0.04] px-5 py-4">
              <div class="flex items-start gap-3">
                <svg class="h-5 w-5 text-quantum flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.352.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <div>
                  <p class="text-sm font-semibold text-quantum mb-1">PQC-Verified{algorithm ? ` with ${algorithm}` : ''}</p>
                  <p class="text-xs text-gray-400">All file hashes match the source. Signature chain includes {model.signatures.length} verification(s). Last verified {model.updated_at?.slice(0, 10) || 'N/A'}.</p>
                </div>
              </div>
            </div>
          ) : (
            <div class="rounded-xl border border-yellow-500/20 bg-yellow-500/[0.04] px-5 py-4">
              <div class="flex items-start gap-3">
                <svg class="h-5 w-5 text-yellow-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <div>
                  <p class="text-sm font-semibold text-yellow-400 mb-1">Unverified Model</p>
                  <p class="text-xs text-gray-400">This model has not been PQC-verified. File integrity cannot be guaranteed against quantum threats.</p>
                </div>
              </div>
            </div>
          )}

          <!-- README / Model Card -->
          <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
            <div class="px-5 py-3 border-b border-white/5 flex items-center gap-2">
              <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              <h2 class="text-sm font-semibold text-gray-300">README.md</h2>
            </div>
            <div class="px-6 py-5 prose prose-invert prose-sm max-w-none">
              <h2 class="text-lg font-bold text-white mb-3">{model.name}</h2>
              <p class="text-sm text-gray-400 leading-relaxed mb-4">{model.description || 'No model card available.'}</p>

              {(model.framework || model.parameters) && (
                <div class="mb-4">
                  <h3 class="text-sm font-semibold text-gray-300 mb-2">Model Details</h3>
                  <table class="text-xs w-full">
                    <tbody>
                      {model.framework && (
                        <tr class="border-b border-white/5">
                          <td class="py-1.5 pr-4 text-gray-500 font-medium">Framework</td>
                          <td class="py-1.5 text-gray-300">{model.framework}</td>
                        </tr>
                      )}
                      {model.parameters && (
                        <tr class="border-b border-white/5">
                          <td class="py-1.5 pr-4 text-gray-500 font-medium">Parameters</td>
                          <td class="py-1.5 text-gray-300 font-mono">{model.parameters}</td>
                        </tr>
                      )}
                      {model.license && (
                        <tr class="border-b border-white/5">
                          <td class="py-1.5 pr-4 text-gray-500 font-medium">License</td>
                          <td class="py-1.5 text-gray-300">{model.license}</td>
                        </tr>
                      )}
                      {algorithm && (
                        <tr class="border-b border-white/5">
                          <td class="py-1.5 pr-4 text-gray-500 font-medium">Signature Algorithm</td>
                          <td class="py-1.5 text-gray-300 font-mono">{algorithm}</td>
                        </tr>
                      )}
                      {model.source_platform && (
                        <tr class="border-b border-white/5">
