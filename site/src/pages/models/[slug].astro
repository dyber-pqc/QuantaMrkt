                      {model.ollama_name && (
                        <tr class="border-b border-white/5">
                          <td class="py-1.5 pr-4 text-gray-500 font-medium">Ollama</td>
                          <td class="py-1.5 text-gray-300 font-mono">{model.ollama_name}</td>
                        </tr>
                      )}
                    </tbody>
                  </table>
                </div>
              )}

              <div class="mb-4">
                <h3 class="text-sm font-semibold text-gray-300 mb-2">Intended Uses</h3>
                <p class="text-xs text-gray-400 leading-relaxed">
                  This model is registered on the QuantaMrkt quantum-safe registry.
                  {model.verified
                    ? ' All files have been cryptographically verified using post-quantum signatures.'
                    : ' This model has not yet been PQC-verified.'}
                </p>
              </div>

              <div>
                <h3 class="text-sm font-semibold text-gray-300 mb-2">Quick Start</h3>
                <div class="rounded-lg bg-navy-900 border border-white/5 p-4">
                  <pre class="text-xs text-gray-400 font-mono whitespace-pre-wrap"><span class="text-gray-600"># Install the CLI</span>
pip install quantumshield

<span class="text-gray-600"># Pull the model</span>
quantumshield pull {model.author}/{model.name}

<span class="text-gray-600"># Verify file integrity</span>
quantumshield verify {model.author}/{model.name}</pre>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ===== FILES TAB ===== -->
        <div id="tab-files" class="tab-panel hidden">
          <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
            <div class="px-5 py-3 border-b border-white/5 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                <h2 class="text-sm font-semibold text-gray-300">File Manifest</h2>
              </div>
              <span class="text-xs text-gray-600">{model.files.length} files &middot; {formatSize(totalSize)} &middot; SHA3-256</span>
            </div>
            {model.files.length > 0 ? (
              <div class="overflow-x-auto">
                <table class="w-full text-xs">
                  <thead>
                    <tr class="border-b border-white/5 text-gray-500">
                      <th class="text-left font-medium px-5 py-2.5">Name</th>
                      <th class="text-left font-medium px-5 py-2.5 hidden md:table-cell">SHA3-256</th>
                      <th class="text-right font-medium px-5 py-2.5">Size</th>
                    </tr>
                  </thead>
                  <tbody>
                    {fileTree.map((node, i: number) => (
                      <tr class={`border-b border-white/[0.03] hover:bg-white/[0.02] transition-colors ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`}>
                        <td class="px-5 py-2">
                          <div class="flex items-center gap-2" style={`padding-left: ${node.depth * 16}px`}>
                            {node.isDir ? (
                              <svg class="h-4 w-4 text-electric/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                            ) : (
                              <svg class="h-4 w-4 text-gray-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                            )}
                            <span class={`font-mono ${node.isDir ? 'text-electric/80 font-medium' : 'text-gray-300'}`}>{node.name}</span>
                          </div>
                        </td>
                        <td class="px-5 py-2 hidden md:table-cell">
                          {!node.isDir && node.hash ? (
                            <span class="font-mono text-[10px] text-gray-600 cursor-pointer hover:text-gray-400 transition-colors" data-copy={node.hash} title={node.hash}>{node.hash.slice(0, 16)}...{node.hash.slice(-8)}</span>
                          ) : (
                            <span class="text-gray-700">--</span>
                          )}
                        </td>
                        <td class="px-5 py-2 text-right">
                          {!node.isDir ? (
                            <span class="text-gray-500 whitespace-nowrap font-mono">{formatSize(node.size)}</span>
                          ) : (
                            <span class="text-gray-700">--</span>
                          )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="px-5 py-12 text-center">
                <svg class="h-8 w-8 text-gray-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                <p class="text-xs text-gray-600">No files in manifest.</p>
              </div>
            )}
          </div>
        </div>

        <!-- ===== SIGNATURES TAB ===== -->
        <div id="tab-signatures" class="tab-panel hidden">
          <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
            <div class="px-5 py-3 border-b border-white/5 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                <h2 class="text-sm font-semibold text-gray-300">Signature Chain</h2>
              </div>
              <span class="text-xs text-gray-600">{model.signatures.length} signature(s)</span>
            </div>
            <div class="p-5">
              {model.signatures.length > 0 ? (
                <div class="space-y-0">
                  {model.signatures.map((sig: any, i: number) => (
                    <div class="flex items-start gap-4">
                      <div class="flex flex-col items-center">
                        <div class={`flex h-8 w-8 items-center justify-center rounded-full text-xs font-bold ${sigRoleIcon(sig.attestation_type)}`}>
                          {i + 1}
                        </div>
                        {i < model.signatures.length - 1 && (
                          <div class="w-px h-full min-h-[40px] bg-white/10 my-1" />
                        )}
                      </div>
                      <div class={`flex-1 rounded-lg border border-white/5 bg-navy-900 p-4 ${i < model.signatures.length - 1 ? 'mb-3' : ''}`}>
                        <div class="flex items-center gap-2 flex-wrap mb-2">
                          <span class="text-xs font-semibold text-gray-200">{sigRoleLabel(sig.attestation_type)}</span>
                          <span class="inline-flex rounded-full bg-white/5 px-2 py-0.5 font-mono text-[10px] text-gray-500">{sig.algorithm}</span>
                          {model.verified && (
                            <span class="inline-flex items-center gap-1 text-[10px] text-quantum">
                              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                              Verified
                            </span>
                          )}
                          <span class="text-[10px] text-gray-600 ml-auto">{sig.signed_at ? new Date(sig.signed_at).toLocaleString() : ''}</span>
                        </div>
                        <div class="space-y-1.5">
                          <div class="flex items-start gap-2">
                            <span class="text-[10px] text-gray-600 w-14 flex-shrink-0 pt-0.5">Signer</span>
                            <span class="font-mono text-[11px] text-gray-400 break-all">{sig.signer_did}</span>
                          </div>
                          <details class="group">
                            <summary class="text-[10px] text-electric cursor-pointer hover:underline">Show full signature</summary>
                            <div class="mt-2 rounded bg-black/30 p-2.5 overflow-x-auto">
                              <code class="font-mono text-[10px] text-gray-500 break-all">{sig.signature_hex}</code>
                            </div>
                          </details>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="text-center py-8">
                  <svg class="h-8 w-8 text-gray-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                  <p class="text-xs text-gray-600">No signatures recorded.</p>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- ===== HNDL RISK TAB ===== -->
        <div id="tab-hndl" class="tab-panel hidden">
