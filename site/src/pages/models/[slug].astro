              <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
              <h2 class="text-sm font-semibold text-gray-300">HNDL Risk Assessment</h2>
            </div>
            <div class="p-5">
              {model.hndl ? (
                <div class="space-y-6">
                  <!-- Risk gauge + metrics -->
                  <div class="flex flex-col sm:flex-row items-center gap-8">
                    <div class="relative h-32 w-32 flex-shrink-0">
                      <svg class="h-32 w-32 -rotate-90" viewBox="0 0 128 128">
                        <circle cx="64" cy="64" r="54" fill="none" stroke="currentColor" stroke-width="8" class="text-white/5" />
                        <circle cx="64" cy="64" r="54" fill="none" stroke="currentColor" stroke-width="8"
                          stroke-dasharray={`${(riskScore / 100) * 339.3} 339.3`}
                          class={riskGaugeColor(riskLevel)} stroke-linecap="round" />
                      </svg>
                      <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-3xl font-bold text-white font-mono">{Math.round(riskScore)}</span>
                        <span class="text-[10px] text-gray-500 mt-0.5">/ 100</span>
                      </div>
                    </div>
                    <div class="flex-1 grid grid-cols-2 gap-4">
                      <div class="rounded-lg border border-white/5 bg-navy-900 p-4">
                        <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Risk Level</p>
                        <p class={`text-sm font-bold ${riskGaugeColor(riskLevel)}`}>{riskLevel}</p>
                      </div>
                      <div class="rounded-lg border border-white/5 bg-navy-900 p-4">
                        <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Quantum Shelf Life</p>
                        <p class="text-sm font-bold text-white font-mono">{shelfLife}</p>
                      </div>
                      <div class="rounded-lg border border-white/5 bg-navy-900 p-4">
                        <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">PQC Status</p>
                        <p class={`text-sm font-bold ${model.verified ? 'text-quantum' : 'text-gray-500'}`}>{model.verified ? 'Verified' : 'Unverified'}</p>
                      </div>
                      <div class="rounded-lg border border-white/5 bg-navy-900 p-4">
                        <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Sensitivity</p>
                        <p class="text-sm font-bold text-white">{model.hndl.sensitivity || 'N/A'}</p>
                      </div>
                    </div>
                  </div>

                  <!-- Timeline visualization -->
                  {model.hndl.shelf_life_years && (
                    <div class="rounded-lg border border-white/5 bg-navy-900 p-4">
                      <p class="text-xs font-medium text-gray-400 mb-3">Quantum Safety Timeline</p>
                      <div class="relative h-3 rounded-full bg-white/5 overflow-hidden">
                        <div
                          class={`absolute left-0 top-0 h-full rounded-full ${
                            model.hndl.shelf_life_years >= 10 ? 'bg-emerald-500' :
                            model.hndl.shelf_life_years >= 5 ? 'bg-yellow-500' : 'bg-red-500'
                          }`}
                          style={`width: ${Math.min((model.hndl.shelf_life_years / 15) * 100, 100)}%`}
                        />
                      </div>
                      <div class="flex justify-between text-[10px] text-gray-600 mt-1.5">
                        <span>Now</span>
                        <span>{model.hndl.shelf_life_years}yr safe</span>
                        <span>15 years</span>
                      </div>
                    </div>
                  )}

                  <!-- Recommendation -->
                  {recommendation && (
                    <div class="rounded-lg border border-yellow-500/10 bg-yellow-500/[0.03] p-4">
                      <h3 class="text-xs font-semibold text-yellow-400 mb-2">Recommendation</h3>
                      <p class="text-xs text-gray-400 leading-relaxed">{recommendation}</p>
                    </div>
                  )}
                </div>
              ) : (
                <div class="text-center py-12">
                  <svg class="h-10 w-10 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
                  <p class="text-sm text-gray-500 mb-1">No HNDL assessment available</p>
                  <p class="text-xs text-gray-600">Request a Harvest Now, Decrypt Later risk assessment for this model.</p>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- ===== ACTIVITY TAB ===== -->
        <div id="tab-activity" class="tab-panel hidden">
          <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
            <div class="px-5 py-3 border-b border-white/5 flex items-center gap-2">
              <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <h2 class="text-sm font-semibold text-gray-300">Transparency Log</h2>
            </div>
            <div id="activity-list" class="p-5">
              <div class="flex items-center justify-center py-8">
                <div class="flex items-center gap-2 text-xs text-gray-500">
                  <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" /><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" /></svg>
                  Loading activity log...
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ===== RIGHT SIDEBAR ===== -->
      <div class="space-y-5">
        <!-- About -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
