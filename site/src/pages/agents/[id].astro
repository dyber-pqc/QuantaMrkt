---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { getAgentById } from '../../lib/db';

const { id } = Astro.params;
const db = (Astro.locals as any).runtime?.env?.DB;
const agent = db && id ? await getAgentById(db, Number(id)) : null;
if (!agent) return Astro.redirect('/agents');

const capabilities: string[] = (() => {
  try { return JSON.parse(agent.capabilities_json || '[]'); } catch { return []; }
})();

const statusColor = agent.status === 'active'
  ? 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20'
  : agent.status === 'revoked'
    ? 'text-red-400 bg-red-500/10 border-red-500/20'
    : 'text-yellow-400 bg-yellow-500/10 border-yellow-500/20';

const statusDot = agent.status === 'active' ? 'bg-emerald-400' : agent.status === 'revoked' ? 'bg-red-400' : 'bg-yellow-400';

// Extract org from name
const orgName = agent.name?.includes('/') ? agent.name.split('/')[0] : null;
const shortName = agent.name?.includes('/') ? agent.name.split('/')[1] : agent.name;

// DID display
const didShort = agent.did.length > 40 ? agent.did.slice(0, 20) + '...' + agent.did.slice(-16) : agent.did;

// Public key fingerprint (first 16 chars of hex)
const fingerprint = agent.public_key_hex ? agent.public_key_hex.slice(0, 32) : null;
---

<MarketingLayout title={`${agent.name} - Agent`} description={`PQC-authenticated agent: ${agent.name}`}>
  <div class="mx-auto max-w-5xl px-6 py-8">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-gray-500 mb-6">
      <a href="/agents" class="hover:text-gray-300 transition-colors">Agents</a>
      <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      <span class="text-gray-300">{agent.name}</span>
    </nav>

    <!-- Agent Header -->
    <div class="rounded-xl border border-white/5 bg-navy-800 p-6 mb-6">
      <div class="flex flex-col sm:flex-row sm:items-start gap-5">
        <!-- Avatar -->
        <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-electric/20 to-quantum/20 text-2xl font-bold text-electric flex-shrink-0">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </div>

        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 flex-wrap mb-2">
            <h1 class="text-2xl font-bold text-white">
              {orgName && (
                <span class="text-electric">{orgName}<span class="text-gray-600 mx-0.5">/</span></span>
              )}
              {shortName}
            </h1>
            <span class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-0.5 text-xs font-medium ${statusColor}`}>
              <span class={`h-1.5 w-1.5 rounded-full ${statusDot}`} />
              {agent.status.charAt(0).toUpperCase() + agent.status.slice(1)}
            </span>
            <span class="inline-flex rounded-full bg-electric/10 border border-electric/20 px-2.5 py-0.5 text-[11px] font-mono font-medium text-electric">
              {agent.algorithm}
            </span>
          </div>

          <!-- DID -->
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[10px] text-gray-600 uppercase tracking-wider">DID</span>
            <code class="text-xs font-mono text-gray-400 bg-navy-900 rounded px-2 py-0.5 border border-white/5 truncate max-w-md" title={agent.did}>{didShort}</code>
            <button data-copy={agent.did} class="rounded border border-white/10 bg-white/5 px-1.5 py-0.5 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors">
              Copy
            </button>
          </div>

          <p class="text-xs text-gray-500">
            Registered {agent.created_at?.slice(0, 10) || 'N/A'}
            {orgName && (<span> &middot; Organization: <span class="text-gray-400">{orgName}</span></span>)}
          </p>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-2 flex-shrink-0">
          <button id="verify-agent-btn" class="rounded-lg border border-quantum/30 bg-quantum/10 text-xs text-quantum px-4 py-2 hover:bg-quantum/20 transition-colors font-medium">
            Verify Identity
          </button>
        </div>
      </div>
    </div>

    <!-- Verify Result -->
    <div id="verify-result" class="hidden rounded-xl border px-5 py-4 mb-6 text-sm"></div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Identity Card -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-5 py-3 border-b border-white/5 flex items-center gap-2">
            <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" /></svg>
            <h2 class="text-sm font-semibold text-gray-300">Identity Card</h2>
          </div>
          <div class="p-5 space-y-3">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div class="rounded-lg border border-white/5 bg-navy-900 p-3">
                <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Full DID</p>
                <p class="font-mono text-[11px] text-gray-300 break-all">{agent.did}</p>
              </div>
              <div class="rounded-lg border border-white/5 bg-navy-900 p-3">
                <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Algorithm</p>
                <p class="font-mono text-sm text-electric">{agent.algorithm}</p>
              </div>
              {fingerprint && (
                <div class="rounded-lg border border-white/5 bg-navy-900 p-3">
                  <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Public Key Fingerprint</p>
                  <p class="font-mono text-[11px] text-gray-400">{fingerprint.match(/.{1,4}/g)?.join(':')}</p>
                </div>
              )}
              <div class="rounded-lg border border-white/5 bg-navy-900 p-3">
                <p class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Registered</p>
                <p class="text-sm text-gray-300">{agent.created_at ? new Date(agent.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A'}</p>
              </div>
            </div>

            {agent.public_key_hex && (
              <details class="group">
                <summary class="text-[10px] text-electric cursor-pointer hover:underline">Show full public key</summary>
                <div class="mt-2 rounded-lg bg-black/30 border border-white/5 p-3 overflow-x-auto">
                  <code class="font-mono text-[10px] text-gray-500 break-all">{agent.public_key_hex}</code>
                </div>
              </details>
            )}
          </div>
        </div>

        <!-- Capabilities -->
        {capabilities.length > 0 && (
          <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
            <div class="px-5 py-3 border-b border-white/5 flex items-center gap-2">
              <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
              <h2 class="text-sm font-semibold text-gray-300">Capabilities</h2>
            </div>
            <div class="p-5">
              <div class="flex flex-wrap gap-2">
                {capabilities.map((cap: string) => (
                  <span class="inline-flex items-center gap-1.5 rounded-lg bg-electric/5 border border-electric/10 px-3 py-1.5 text-xs text-electric">
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    {cap}
                  </span>
                ))}
              </div>
            </div>
          </div>
        )}

        <!-- Delegation Chain -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-5 py-3 border-b border-white/5 flex items-center gap-2">
            <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
            <h2 class="text-sm font-semibold text-gray-300">Delegation Chain</h2>
          </div>
          <div class="p-5">
            <div class="flex items-start gap-3">
              <!-- Root authority -->
              <div class="flex flex-col items-center">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-quantum/10 text-quantum">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>
                <div class="w-px h-8 bg-white/10 my-1" />
              </div>
              <div class="flex-1 pb-4">
                <p class="text-xs font-semibold text-quantum mb-0.5">Root Authority</p>
                <p class="text-[10px] text-gray-500">QuantaMrkt Registry</p>
                <p class="font-mono text-[10px] text-gray-600 mt-0.5">did:quantamrkt:registry</p>
              </div>
            </div>
            {orgName && (
              <div class="flex items-start gap-3">
                <div class="flex flex-col items-center">
                  <div class="flex h-8 w-8 items-center justify-center rounded-full bg-electric/10 text-electric">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                  </div>
                  <div class="w-px h-8 bg-white/10 my-1" />
                </div>
                <div class="flex-1 pb-4">
                  <p class="text-xs font-semibold text-electric mb-0.5">Organization</p>
                  <p class="text-[10px] text-gray-400">{orgName}</p>
                  <p class="font-mono text-[10px] text-gray-600 mt-0.5">did:quantamrkt:org:{orgName}</p>
                </div>
              </div>
            )}
            <div class="flex items-start gap-3">
              <div class="flex flex-col items-center">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-gray-300">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
              </div>
              <div class="flex-1">
                <p class="text-xs font-semibold text-gray-200 mb-0.5">This Agent</p>
                <p class="text-[10px] text-gray-400">{agent.name}</p>
                <p class="font-mono text-[10px] text-gray-600 mt-0.5">{agent.did}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Activity Timeline -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-5 py-3 border-b border-white/5 flex items-center gap-2">
            <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <h2 class="text-sm font-semibold text-gray-300">Activity Timeline</h2>
          </div>
          <div id="agent-activity" class="p-5">
            <div class="flex items-center justify-center py-8">
              <div class="flex items-center gap-2 text-xs text-gray-500">
                <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" /><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" /></svg>
                Loading activity...
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-5">
        <!-- Quick Info -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-4 py-3 border-b border-white/5">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Details</h3>
          </div>
          <div class="divide-y divide-white/[0.03]">
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-[11px] text-gray-500">Status</span>
              <span class={`inline-flex items-center gap-1 text-[11px] ${agent.status === 'active' ? 'text-emerald-400' : 'text-yellow-400'}`}>
                <span class={`h-1.5 w-1.5 rounded-full ${statusDot}`} />
                {agent.status.charAt(0).toUpperCase() + agent.status.slice(1)}
              </span>
            </div>
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-[11px] text-gray-500">Algorithm</span>
              <span class="font-mono text-[11px] text-electric">{agent.algorithm}</span>
            </div>
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-[11px] text-gray-500">Capabilities</span>
              <span class="text-[11px] text-gray-300">{capabilities.length}</span>
            </div>
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-[11px] text-gray-500">Registered</span>
              <span class="text-[11px] text-gray-300">{agent.created_at?.slice(0, 10) || 'N/A'}</span>
            </div>
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-[11px] text-gray-500">Agent ID</span>
              <span class="font-mono text-[11px] text-gray-300">#{agent.id}</span>
            </div>
          </div>
        </div>

        <!-- Verify this agent -->
        <div class="rounded-xl border border-white/5 bg-navy-800 p-4">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Verify via CLI</h3>
          <div class="rounded-lg bg-navy-900 border border-white/5 p-3 relative group">
            <code class="text-[11px] font-mono text-quantum break-all">quantumshield agent verify {agent.did}</code>
            <button data-copy={`quantumshield agent verify ${agent.did}`} class="absolute top-2 right-2 rounded border border-white/10 bg-white/5 px-1.5 py-0.5 text-[10px] text-gray-500 hover:bg-white/10 hover:text-white transition-colors opacity-0 group-hover:opacity-100">Copy</button>
          </div>
        </div>

        <!-- Links -->
        <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
          <div class="px-4 py-3 border-b border-white/5">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Links</h3>
          </div>
          <div class="p-4 space-y-2">
            <a href={`/api/agents/${agent.id}`} target="_blank" class="flex items-center gap-2 text-xs text-gray-400 hover:text-white transition-colors">
              <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
              API Endpoint
            </a>
            <a href="/agents" class="flex items-center gap-2 text-xs text-gray-400 hover:text-white transition-colors">
              <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
              Agent Directory
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

<script define:vars={{ agentId: agent.id, agentDid: agent.did }}>
  // Copy-to-clipboard
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy || '';
      await navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig || ''; }, 1500);
    });
  });

  // Verify agent identity
  const verifyBtn = document.getElementById('verify-agent-btn');
  const verifyResult = document.getElementById('verify-result');
  if (verifyBtn && verifyResult) {
    verifyBtn.addEventListener('click', async () => {
      verifyBtn.textContent = 'Verifying...';
      verifyBtn.disabled = true;
      try {
        const res = await fetch(`/api/agents/${agentId}/verify`);
        const data = await res.json();
        verifyResult.classList.remove('hidden');
        if (data.valid || data.verified) {
          verifyResult.className = 'rounded-xl border border-emerald-500/20 bg-emerald-500/[0.06] px-5 py-4 mb-6 text-sm text-emerald-400';
          verifyResult.innerHTML = '<strong>Identity verified.</strong> This agent\'s DID and public key are valid and registered.';
        } else {
          verifyResult.className = 'rounded-xl border border-yellow-500/20 bg-yellow-500/[0.06] px-5 py-4 mb-6 text-sm text-yellow-400';
          verifyResult.textContent = data.error || 'Identity verification could not be completed.';
        }
      } catch {
        verifyResult.classList.remove('hidden');
        verifyResult.className = 'rounded-xl border border-red-500/20 bg-red-500/[0.06] px-5 py-4 mb-6 text-sm text-red-400';
        verifyResult.textContent = 'Error contacting verification API.';
      }
      verifyBtn.textContent = 'Verify Identity';
      verifyBtn.disabled = false;
    });
  }

  // Load activity
  async function loadActivity() {
    const container = document.getElementById('agent-activity');
    if (!container) return;
    try {
      const res = await fetch(`/api/agents/${agentId}/activity`);
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      const entries = data.entries || data || [];
      if (entries.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8">
            <svg class="h-8 w-8 text-gray-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <p class="text-xs text-gray-600">No activity recorded for this agent.</p>
          </div>`;
        return;
      }
      container.innerHTML = entries.slice(0, 15).map((entry, i) => `
        <div class="flex items-start gap-3 ${i > 0 ? 'mt-3 pt-3 border-t border-white/5' : ''}">
          <div class="flex h-6 w-6 items-center justify-center rounded-full bg-electric/10 text-electric text-[10px] flex-shrink-0 mt-0.5">
            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-gray-300">${entry.action || 'Activity'}</p>
            ${entry.target ? `<p class="text-[10px] text-gray-500 mt-0.5">${entry.target}</p>` : ''}
            <p class="text-[10px] text-gray-600 mt-0.5">${entry.created_at || ''}</p>
          </div>
        </div>
      `).join('');
    } catch {
      container.innerHTML = `
        <div class="text-center py-8">
          <p class="text-xs text-gray-600">Unable to load activity log.</p>
        </div>`;
    }
  }
  loadActivity();
</script>
</MarketingLayout>
