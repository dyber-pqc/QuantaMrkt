---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const { id } = Astro.params;

const model = {
  id: 'meta-llama-3.1-70b',
  name: 'meta-llama/Llama-3.1-70B-Instruct',
  algorithm: 'ML-DSA-87',
  risk: 'HIGH',
  riskScore: 78,
  shelfLife: '15 years',
  cnsaReady: true,
  files: [
    { name: 'model-00001-of-00030.safetensors', hash: 'a3f2b8c91d4e5f60...c5d6e7', size: '4.7 GB' },
    { name: 'model-00002-of-00030.safetensors', hash: 'b4c3d9e02f5a6b71...d6e7f8', size: '4.7 GB' },
    { name: 'config.json', hash: 'c5d4e0f13a6b7c82...e8f91a', size: '1.2 KB' },
    { name: 'tokenizer.json', hash: 'd6e5f1a24b7c8d93...9f02b3', size: '17.5 MB' },
    { name: 'tokenizer_config.json', hash: 'e7f6a2b35c8d9e04...0a13c4', size: '3.4 KB' },
    { name: 'special_tokens_map.json', hash: 'f8a7b3c46d9e0f15...1b24d5', size: '0.6 KB' },
  ],
  signatures: [
    {
      role: 'Creator',
      signer: 'did:web:meta.com:ml-signing:llama-team',
      algorithm: 'ML-DSA-87',
      date: '2026-03-18T14:32:00Z',
      fingerprint: 'QmX7...f3k2',
    },
    {
      role: 'Verifier',
      signer: 'did:web:quantmrkt.com:verification:primary',
      algorithm: 'ML-DSA-87',
      date: '2026-03-18T14:35:12Z',
      fingerprint: 'QmR9...h8j4',
    },
  ],
  provenance: {
    source: 'huggingface.co/meta-llama/Llama-3.1-70B-Instruct',
    license: 'Llama 3.1 Community License',
    trainedOn: 'Undisclosed web corpus, 15T tokens',
    framework: 'PyTorch 2.4',
  },
  recommendation: 'Weight files vulnerable to harvest-now-decrypt-later attacks within projected shelf life. Migrate to quantum-safe distribution channels and verify all weight file integrity using PQC signatures before deployment.',
};
---

<DashboardLayout title={model.name}>
  <!-- Back + Header -->
  <a href="/dashboard/models" class="inline-flex items-center gap-1 text-xs text-gray-500 hover:text-gray-300 transition-colors mb-3">
    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    Models
  </a>

  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mb-5">
    <div>
      <h2 class="font-mono text-base font-semibold text-white">{model.name}</h2>
      <div class="flex flex-wrap items-center gap-1.5 mt-1.5">
        <span class="badge-verified">{model.algorithm}</span>
        {model.cnsaReady && <span class="inline-flex items-center gap-1 rounded-full bg-quantum/10 px-2 py-0.5 text-xs text-quantum">CNSA 2.0</span>}
        <span class="badge-high">HNDL: {model.risk}</span>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button class="inline-flex items-center gap-1.5 rounded-md bg-navy-700 border border-white/10 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-navy-600 hover:text-white transition-colors">
        Copy Hash
      </button>
      <button class="inline-flex items-center gap-1.5 rounded-md bg-navy-700 border border-white/10 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-navy-600 hover:text-white transition-colors">
        Download Manifest
      </button>
      <button class="inline-flex items-center gap-1.5 rounded-md bg-electric/15 border border-electric/20 px-3 py-1.5 text-xs font-medium text-electric hover:bg-electric/25 transition-colors">
        Verify Signature
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-5 lg:grid-cols-4">
    <!-- Left: Files + Signatures + Provenance -->
    <div class="lg:col-span-3 space-y-5">
      <!-- File Manifest -->
      <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-white/5 flex items-center justify-between">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">File Manifest</h3>
          <span class="text-xs text-gray-600">{model.files.length} files</span>
        </div>
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-white/5 text-gray-500">
              <th class="text-left font-medium px-4 py-2">Filename</th>
              <th class="text-left font-medium px-4 py-2">SHA3-256</th>
              <th class="text-right font-medium px-4 py-2">Size</th>
            </tr>
          </thead>
          <tbody>
            {model.files.map((file, i) => (
              <tr class={`border-b border-white/[0.03] ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`}>
                <td class="px-4 py-2">
                  <span class="font-mono text-gray-300">{file.name}</span>
                </td>
                <td class="px-4 py-2">
                  <span class="font-mono text-gray-500">{file.hash}</span>
                </td>
                <td class="px-4 py-2 text-right">
                  <span class="text-gray-500 whitespace-nowrap">{file.size}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Signature Chain -->
      <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-white/5">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Signature Chain</h3>
        </div>
        <div class="p-4">
          {model.signatures.map((sig, i) => (
            <div class="flex items-start gap-3">
              <div class="flex flex-col items-center">
                <div class={`flex h-5 w-5 items-center justify-center rounded-full text-[10px] font-bold ${
                  i === 0 ? 'bg-electric/15 text-electric' : 'bg-quantum/15 text-quantum'
                }`}>
                  {i + 1}
                </div>
                {i < model.signatures.length - 1 && (
                  <div class="w-px h-10 bg-white/10 my-1" />
                )}
              </div>
              <div class={`flex-1 ${i < model.signatures.length - 1 ? 'pb-4' : ''}`}>
                <div class="flex items-center gap-2">
                  <span class="text-xs font-medium text-gray-300">{sig.role}</span>
                  <span class="font-mono text-xs text-gray-500">{sig.algorithm}</span>
                  <span class="text-xs text-gray-600">{new Date(sig.date).toLocaleDateString()}</span>
                </div>
                <p class="font-mono text-xs text-gray-500 mt-0.5">{sig.signer}</p>
                <p class="text-xs text-gray-600 mt-0.5">Fingerprint: <span class="font-mono">{sig.fingerprint}</span></p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Provenance -->
      <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-white/5">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Provenance</h3>
        </div>
        <div class="px-4 py-3 grid grid-cols-2 gap-x-8 gap-y-2 text-xs">
          <div>
            <span class="text-gray-500">Source</span>
            <p class="font-mono text-gray-300 mt-0.5">{model.provenance.source}</p>
          </div>
          <div>
            <span class="text-gray-500">License</span>
            <p class="text-gray-300 mt-0.5">{model.provenance.license}</p>
          </div>
          <div>
            <span class="text-gray-500">Training Data</span>
            <p class="text-gray-300 mt-0.5">{model.provenance.trainedOn}</p>
          </div>
          <div>
            <span class="text-gray-500">Framework</span>
            <p class="text-gray-300 mt-0.5">{model.provenance.framework}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Sidebar -->
    <div class="space-y-5">
      <!-- HNDL Risk Score -->
      <div class="rounded-lg border border-white/5 bg-navy-800 p-4">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">HNDL Risk</h3>
        <div class="flex items-center justify-center mb-3">
          <div class="relative h-20 w-20">
            <svg class="h-20 w-20 -rotate-90" viewBox="0 0 80 80">
              <circle cx="40" cy="40" r="34" fill="none" stroke="currentColor" stroke-width="5" class="text-white/5" />
              <circle cx="40" cy="40" r="34" fill="none" stroke="currentColor" stroke-width="5"
                stroke-dasharray={`${(model.riskScore / 100) * 213.6} 213.6`}
                class="text-warning" stroke-linecap="round" />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-lg font-bold text-white font-mono">{model.riskScore}</span>
            </div>
          </div>
        </div>
        <div class="space-y-2 text-xs">
          <div class="flex items-center justify-between">
            <span class="text-gray-500">Risk Level</span>
            <span class="badge-high">{model.risk}</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-500">Shelf Life</span>
            <span class="font-mono text-gray-300">{model.shelfLife}</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-500">CNSA 2.0</span>
            <span class="text-quantum text-xs">Ready</span>
          </div>
        </div>
      </div>

      <!-- Recommendation -->
      <div class="rounded-lg border border-warning/10 bg-warning/[0.03] p-4">
        <h3 class="text-xs font-semibold text-warning mb-2">Advisory</h3>
        <p class="text-xs text-gray-400 leading-relaxed">{model.recommendation}</p>
      </div>
    </div>
  </div>
</DashboardLayout>
