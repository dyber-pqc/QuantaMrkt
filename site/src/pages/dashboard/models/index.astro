---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import type { User } from '../../../lib/auth';
import { getUserModels, getUserByGithubId } from '../../../lib/db';

const user = (Astro.locals as any).user as User | undefined;
const db = (Astro.locals as any).runtime?.env?.DB;

let models: any[] = [];
if (db && user) {
  const dbUser = await getUserByGithubId(db, (user as any).id ?? (user as any).github_id);
  if (dbUser) {
    models = await getUserModels(db, dbUser.login);
  }
}

function formatDownloads(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return String(n);
}

function riskBadgeClass(level: string | null | undefined): string {
  if (!level) return 'badge-low';
  switch (level.toUpperCase()) {
    case 'CRITICAL': return 'badge-critical';
    case 'HIGH': return 'badge-high';
    case 'MEDIUM': return 'badge-medium';
    default: return 'badge-low';
  }
}

function parseTags(tags: string | null | undefined): string[] {
  if (!tags) return [];
  try { return JSON.parse(tags); } catch { return []; }
}
---

<DashboardLayout title="Your Models">
  {models.length > 0 ? (
    <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
      <div class="px-4 py-2.5 border-b border-white/5 flex items-center justify-between">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Signed Models</h2>
        <span class="text-xs text-gray-600">{models.length} model{models.length !== 1 ? 's' : ''}</span>
      </div>
      <div class="divide-y divide-white/[0.03]">
        {models.map((model: any) => {
          const tags = parseTags(model.tags);
          return (
            <a href={`/models/${model.slug}`} class="flex items-start gap-3 px-4 py-3 hover:bg-white/[0.02] transition-colors group">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-sm font-bold text-gray-400 flex-shrink-0 mt-0.5">
                {model.author?.[0]?.toUpperCase() || '?'}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5">
                  <span class="text-sm font-medium text-gray-200 group-hover:text-white">{model.author}/{model.name}</span>
                  {model.verified ? (
                    <span class="inline-flex items-center gap-1 text-[10px] text-quantum">
                      <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.352.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                      Verified
                    </span>
                  ) : (
                    <span class="text-[10px] text-gray-500">Unverified</span>
                  )}
                </div>
                <p class="text-xs text-gray-400 line-clamp-1 mb-1">{model.description}</p>
                <div class="flex items-center gap-2 flex-wrap">
                  {tags.slice(0, 3).map((tag: string) => (
                    <span class="inline-flex rounded-md bg-white/5 px-1.5 py-0.5 text-[10px] text-gray-500">{tag}</span>
                  ))}
                  {model.risk_level && <span class={riskBadgeClass(model.risk_level) + ' !text-[10px] !px-1.5 !py-0'}>{model.risk_level}</span>}
                </div>
              </div>
              <div class="hidden sm:flex flex-col items-end gap-1 flex-shrink-0 text-right">
                <span class="text-[11px] text-gray-500">{formatDownloads(model.downloads ?? 0)} downloads</span>
                <span class="text-[10px] text-gray-600">{model.sig_count ?? model.signature_count ?? 0} signatures</span>
                <button
                  data-delete-model={model.slug}
                  class="mt-1 inline-flex items-center gap-1 rounded-md bg-red-500/10 border border-red-500/20 px-2 py-0.5 text-[10px] font-medium text-red-400 hover:bg-red-500/20 transition-colors"
                  onclick="event.preventDefault(); event.stopPropagation();"
                >
                  Delete
                </button>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  ) : (
    <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
      <div class="px-4 py-2.5 border-b border-white/5 flex items-center justify-between">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Signed Models</h2>
        <span class="text-xs text-gray-600">0 models</span>
      </div>
      <div class="px-4 py-16 text-center">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white/5 mx-auto mb-4">
          <svg class="h-6 w-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
        <p class="text-sm font-medium text-gray-300 mb-1">You haven't signed any models yet</p>
        <p class="text-xs text-gray-500 max-w-md mx-auto mb-5">
          Sign your first model from the CLI or upload one here. Signed models appear in the public marketplace with your verification stamp.
        </p>

        <div class="max-w-lg mx-auto mb-6 text-left space-y-3">
          <p class="text-[11px] text-gray-600 mb-3 uppercase tracking-wider font-medium text-center">Get started in 4 steps</p>
          <div class="rounded-md bg-navy-900 border border-white/5 px-4 py-2.5 flex items-start gap-3">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-electric/15 text-electric text-[10px] font-bold shrink-0 mt-0.5">1</span>
            <div>
              <p class="text-xs text-gray-300 font-medium">Install the CLI</p>
              <code class="text-[11px] font-mono text-gray-500">pip install quantumshield</code>
            </div>
          </div>
          <div class="rounded-md bg-navy-900 border border-white/5 px-4 py-2.5 flex items-start gap-3">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-electric/15 text-electric text-[10px] font-bold shrink-0 mt-0.5">2</span>
            <div>
              <p class="text-xs text-gray-300 font-medium">Authenticate</p>
              <code class="text-[11px] font-mono text-gray-500">quantumshield login</code>
            </div>
          </div>
          <div class="rounded-md bg-navy-900 border border-white/5 px-4 py-2.5 flex items-start gap-3">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-electric/15 text-electric text-[10px] font-bold shrink-0 mt-0.5">3</span>
            <div>
              <p class="text-xs text-gray-300 font-medium">Create a signing identity</p>
              <code class="text-[11px] font-mono text-gray-500">quantumshield agent create my-signer --set-default</code>
            </div>
          </div>
          <div class="rounded-md bg-navy-900 border border-white/5 px-4 py-2.5 flex items-start gap-3">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-quantum/15 text-quantum text-[10px] font-bold shrink-0 mt-0.5">4</span>
            <div>
              <p class="text-xs text-gray-300 font-medium">Push your model</p>
              <code class="text-[11px] font-mono text-gray-500">quantumshield push ./my-model --name yourname/model-name</code>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-center gap-3">
          <a href="/models" class="inline-flex items-center gap-1.5 rounded-md bg-electric/15 border border-electric/20 px-3 py-1.5 text-xs font-medium text-electric hover:bg-electric/25 transition-colors">
            Browse Marketplace
          </a>
          <a href="/docs/quickstart" class="inline-flex items-center gap-1.5 rounded-md bg-white/5 border border-white/10 px-3 py-1.5 text-xs font-medium text-gray-400 hover:bg-white/10 hover:text-white transition-colors">
            Read Docs
          </a>
        </div>
      </div>
    </div>
  )}
  <script>
    document.querySelectorAll('[data-delete-model]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const slug = (btn as HTMLElement).dataset.deleteModel;
        if (!slug) return;
        if (!confirm(`Are you sure you want to delete "${slug}"? This cannot be undone.`)) return;

        (btn as HTMLButtonElement).disabled = true;
        (btn as HTMLButtonElement).textContent = 'Deleting...';

        try {
          const res = await fetch(`/api/models/${slug}/delete`, { method: 'DELETE' });
          const data = await res.json();
          if (res.ok && data.success) {
            // Remove the row from the DOM
            const row = (btn as HTMLElement).closest('a');
            if (row) row.remove();
          } else {
            alert(data.error || 'Failed to delete model.');
            (btn as HTMLButtonElement).disabled = false;
            (btn as HTMLButtonElement).textContent = 'Delete';
          }
        } catch {
          alert('Failed to delete model. Please try again.');
          (btn as HTMLButtonElement).disabled = false;
          (btn as HTMLButtonElement).textContent = 'Delete';
        }
      });
    });
  </script>
</DashboardLayout>
