---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const models = [
  {
    id: 'meta-llama-3.1-70b',
    name: 'Llama-3.1-70B-Instruct',
    author: 'meta-llama',
    algorithm: 'ML-DSA-87',
    risk: 'CRITICAL',
    riskBadge: 'badge-critical',
    date: '2026-03-18',
    files: 24,
    verified: true,
  },
  {
    id: 'mistral-mixtral-8x22b',
    name: 'Mixtral-8x22B-Instruct-v0.1',
    author: 'mistral',
    algorithm: 'ML-DSA-65',
    risk: 'HIGH',
    riskBadge: 'badge-high',
    date: '2026-03-15',
    files: 18,
    verified: true,
  },
  {
    id: 'openai-whisper-large-v3',
    name: 'whisper-large-v3',
    author: 'openai',
    algorithm: 'ML-DSA-87',
    risk: 'MEDIUM',
    riskBadge: 'badge-medium',
    date: '2026-03-12',
    files: 6,
    verified: true,
  },
  {
    id: 'google-gemma-2-27b',
    name: 'gemma-2-27b-it',
    author: 'google',
    algorithm: 'ML-DSA-65',
    risk: 'HIGH',
    riskBadge: 'badge-high',
    date: '2026-03-10',
    files: 12,
    verified: true,
  },
  {
    id: 'stabilityai-sdxl',
    name: 'stable-diffusion-xl-base-1.0',
    author: 'stabilityai',
    algorithm: 'ML-DSA-44',
    risk: 'LOW',
    riskBadge: 'badge-low',
    date: '2026-03-08',
    files: 4,
    verified: false,
  },
  {
    id: 'microsoft-phi-3-medium',
    name: 'Phi-3-medium-128k-instruct',
    author: 'microsoft',
    algorithm: 'ML-DSA-87',
    risk: 'MEDIUM',
    riskBadge: 'badge-medium',
    date: '2026-03-05',
    files: 9,
    verified: true,
  },
];

const riskLevels = ['ALL', 'CRITICAL', 'HIGH', 'MEDIUM', 'LOW'];
---

<DashboardLayout title="Model Registry">
  <!-- Search & Filters -->
  <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="relative flex-1 max-w-md">
      <input
        type="text"
        placeholder="Search models..."
        class="w-full rounded-md border border-white/10 bg-navy-800 pl-8 pr-3 py-1.5 text-sm text-white placeholder-gray-500 focus:border-electric/50 focus:outline-none focus:ring-1 focus:ring-electric/50"
      />
      <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
    <div class="flex items-center gap-1.5">
      {riskLevels.map((level, i) => (
        <button
          class={`rounded-md px-2.5 py-1 text-xs font-medium transition-colors ${
            i === 0
              ? 'bg-electric/15 text-electric'
              : 'bg-white/5 text-gray-500 hover:bg-white/10 hover:text-gray-300'
          }`}
        >
          {level}
        </button>
      ))}
    </div>
  </div>

  <!-- Model List Table -->
  <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-white/5 text-xs text-gray-500">
          <th class="text-left font-medium px-4 py-2.5">Model</th>
          <th class="text-left font-medium px-4 py-2.5">Algorithm</th>
          <th class="text-left font-medium px-4 py-2.5">HNDL Risk</th>
          <th class="text-left font-medium px-4 py-2.5 hidden md:table-cell">Signed</th>
          <th class="text-right font-medium px-4 py-2.5 hidden sm:table-cell">Files</th>
          <th class="text-center font-medium px-4 py-2.5 hidden sm:table-cell">Status</th>
        </tr>
      </thead>
      <tbody>
        {models.map((model, i) => (
          <tr class={`border-b border-white/[0.03] hover:bg-white/[0.03] transition-colors cursor-pointer ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`}>
            <td class="px-4 py-2.5">
              <a href={`/dashboard/models/${model.id}`} class="flex items-center gap-3 group">
                <div class="flex h-7 w-7 items-center justify-center rounded-md bg-white/5 text-xs font-semibold text-gray-400 flex-shrink-0">
                  {model.author[0].toUpperCase()}
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-medium text-gray-200 group-hover:text-white truncate">{model.name}</p>
                  <p class="text-xs text-gray-500">{model.author}</p>
                </div>
              </a>
            </td>
            <td class="px-4 py-2.5">
              <span class="font-mono text-xs text-gray-400">{model.algorithm}</span>
            </td>
            <td class="px-4 py-2.5">
              <span class={model.riskBadge}>{model.risk}</span>
            </td>
            <td class="px-4 py-2.5 hidden md:table-cell">
              <span class="text-xs text-gray-500">{model.date}</span>
            </td>
            <td class="px-4 py-2.5 text-right hidden sm:table-cell">
              <span class="text-xs text-gray-500 font-mono">{model.files}</span>
            </td>
            <td class="px-4 py-2.5 text-center hidden sm:table-cell">
              {model.verified ? (
                <span class="inline-flex h-4 w-4 items-center justify-center rounded-full bg-quantum/15">
                  <svg class="h-2.5 w-2.5 text-quantum" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                </span>
              ) : (
                <span class="inline-flex h-4 w-4 items-center justify-center rounded-full bg-white/5">
                  <span class="h-1.5 w-1.5 rounded-full bg-gray-600" />
                </span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="mt-3 flex items-center justify-between text-xs text-gray-500">
    <span>Showing {models.length} models</span>
    <span class="font-mono">{models.filter(m => m.verified).length} verified</span>
  </div>
</DashboardLayout>
