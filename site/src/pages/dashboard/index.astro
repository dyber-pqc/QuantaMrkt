  <script>
    document.getElementById('sync-hf-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('sync-hf-btn') as HTMLButtonElement;
      const statusEl = document.getElementById('sync-status')!;
      btn.disabled = true;
      statusEl.textContent = 'Syncing...';
      statusEl.className = 'text-[10px] text-electric mt-0.5';

      try {
        const res = await fetch('/api/sync/trigger', { method: 'POST' });
        const data = await res.json();

        if (data.error) {
          statusEl.textContent = data.error;
          statusEl.className = 'text-[10px] text-red-400 mt-0.5';
        } else {
          statusEl.textContent = `Done! ${data.created} created, ${data.updated} updated${data.errors?.length ? `, ${data.errors.length} errors` : ''}`;
          statusEl.className = 'text-[10px] text-green-400 mt-0.5';
        }
      } catch (e) {
        statusEl.textContent = 'Sync failed. Try again.';
        statusEl.className = 'text-[10px] text-red-400 mt-0.5';
      }

      btn.disabled = false;
    });
  </script>
