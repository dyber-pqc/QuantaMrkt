---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const apiKey = {
  name: 'Production Key',
  key: 'qmkt_live_a3f2...7k9x',
  created: '2026-02-01',
  lastUsed: '2026-03-25',
};

const identity = {
  did: 'did:web:acme.corp:users:john.doe',
  algorithm: 'ML-DSA-65',
  created: '2026-01-15T10:00:00Z',
  fingerprint: 'QmT5...x9r2',
};
---

<DashboardLayout title="Settings">
  <div class="max-w-3xl space-y-8">
    <!-- API Keys -->
    <div class="card">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-lg font-semibold text-white">API Keys</h2>
          <p class="text-sm text-gray-400 mt-1">Manage your API keys for programmatic access</p>
        </div>
        <button class="btn-secondary text-sm">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          New Key
        </button>
      </div>

      <div class="rounded-lg border border-white/5 bg-navy-900/50 p-4">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-medium text-white">{apiKey.name}</span>
          <span class="badge bg-quantum/20 text-quantum">Active</span>
        </div>
        <div class="flex items-center gap-2 mb-3">
          <code class="flex-1 rounded bg-navy-800 px-3 py-2 font-mono text-sm text-gray-300 border border-white/5">
            {apiKey.key}
          </code>
          <button class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm text-gray-400 hover:bg-white/10 hover:text-white transition-colors" title="Copy to clipboard">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
          </button>
        </div>
        <div class="flex gap-4 text-xs text-gray-500">
          <span>Created: {apiKey.created}</span>
          <span>Last used: {apiKey.lastUsed}</span>
        </div>
      </div>
    </div>

    <!-- Identity Management -->
    <div class="card">
      <div class="mb-6">
        <h2 class="text-lg font-semibold text-white">Identity Management</h2>
        <p class="text-sm text-gray-400 mt-1">Your decentralized identity for quantum-safe operations</p>
      </div>

      <div class="space-y-4">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between py-3 border-b border-white/5">
          <span class="text-sm text-gray-400 mb-1 sm:mb-0">DID</span>
          <span class="font-mono text-sm text-white break-all">{identity.did}</span>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-white/5">
          <span class="text-sm text-gray-400">Algorithm</span>
          <span class="font-mono text-electric">{identity.algorithm}</span>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-white/5">
          <span class="text-sm text-gray-400">Fingerprint</span>
          <span class="font-mono text-sm text-white">{identity.fingerprint}</span>
        </div>
        <div class="flex items-center justify-between py-3">
          <span class="text-sm text-gray-400">Created</span>
          <span class="text-sm text-white">{new Date(identity.created).toLocaleDateString()}</span>
        </div>
      </div>

      <div class="mt-6 flex gap-3">
        <button class="btn-secondary text-sm">Rotate Key</button>
        <button class="btn-ghost text-sm">Export Public Key</button>
      </div>
    </div>

    <!-- Team Members -->
    <div class="card">
      <div class="mb-6">
        <h2 class="text-lg font-semibold text-white">Team Members</h2>
        <p class="text-sm text-gray-400 mt-1">Collaborate with your team on quantum-safe migrations</p>
      </div>

      <div class="rounded-lg border border-dashed border-white/10 p-8 text-center">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white/5 mx-auto mb-4">
          <svg class="h-6 w-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
        </div>
        <p class="text-sm text-gray-400 mb-1">Team collaboration requires the Team plan</p>
        <p class="text-xs text-gray-500 mb-4">Invite team members, manage roles, and share reports</p>
        <a href="/pricing" class="btn-primary text-sm inline-flex">Upgrade to Team Plan</a>
      </div>
    </div>
  </div>
</DashboardLayout>
