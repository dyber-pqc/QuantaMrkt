---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const apiKey = {
  name: 'Production Key',
  key: 'qmkt_live_a3f2...7k9x',
  created: '2026-02-01',
  lastUsed: '2026-03-25',
};

const identity = {
  did: 'did:web:acme.corp:users:john.doe',
  algorithm: 'ML-DSA-65',
  created: '2026-01-15T10:00:00Z',
  fingerprint: 'QmT5...x9r2',
};
---

<DashboardLayout title="Settings">
  <div class="max-w-2xl space-y-5">
    <!-- API Keys -->
    <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
      <div class="px-4 py-2.5 border-b border-white/5 flex items-center justify-between">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">API Keys</h2>
        <button class="inline-flex items-center gap-1.5 rounded-md bg-white/5 border border-white/10 px-2.5 py-1 text-xs font-medium text-gray-400 hover:bg-white/10 hover:text-white transition-colors">
          New Key
        </button>
      </div>
      <div class="p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium text-gray-300">{apiKey.name}</span>
          <span class="inline-flex items-center gap-1.5 text-xs text-quantum">
            <span class="h-1.5 w-1.5 rounded-full bg-quantum" />
            Active
          </span>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <code class="flex-1 rounded-md bg-navy-900 px-3 py-1.5 font-mono text-xs text-gray-400 border border-white/5">
            {apiKey.key}
          </code>
          <button class="rounded-md border border-white/10 bg-white/5 px-2 py-1.5 text-gray-500 hover:bg-white/10 hover:text-white transition-colors" title="Copy to clipboard">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
          </button>
        </div>
        <div class="flex gap-4 text-[11px] text-gray-600">
          <span>Created {apiKey.created}</span>
          <span>Last used {apiKey.lastUsed}</span>
        </div>
      </div>
    </div>

    <!-- Identity -->
    <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
      <div class="px-4 py-2.5 border-b border-white/5">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Identity</h2>
      </div>
      <div class="divide-y divide-white/[0.03]">
        <div class="flex items-center justify-between px-4 py-2.5">
          <span class="text-xs text-gray-500">DID</span>
          <span class="font-mono text-xs text-gray-300">{identity.did}</span>
        </div>
        <div class="flex items-center justify-between px-4 py-2.5">
          <span class="text-xs text-gray-500">Algorithm</span>
          <span class="font-mono text-xs text-gray-300">{identity.algorithm}</span>
        </div>
        <div class="flex items-center justify-between px-4 py-2.5">
          <span class="text-xs text-gray-500">Fingerprint</span>
          <span class="font-mono text-xs text-gray-300">{identity.fingerprint}</span>
        </div>
        <div class="flex items-center justify-between px-4 py-2.5">
          <span class="text-xs text-gray-500">Created</span>
          <span class="text-xs text-gray-300">{new Date(identity.created).toLocaleDateString()}</span>
        </div>
      </div>
      <div class="px-4 py-3 border-t border-white/5 flex gap-2">
        <button class="inline-flex items-center gap-1.5 rounded-md bg-white/5 border border-white/10 px-2.5 py-1 text-xs font-medium text-gray-400 hover:bg-white/10 hover:text-white transition-colors">
          Rotate Key
        </button>
        <button class="inline-flex items-center gap-1.5 rounded-md bg-white/5 border border-white/10 px-2.5 py-1 text-xs font-medium text-gray-400 hover:bg-white/10 hover:text-white transition-colors">
          Export Public Key
        </button>
      </div>
    </div>

    <!-- Team -->
    <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
      <div class="px-4 py-2.5 border-b border-white/5">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Team</h2>
      </div>
      <div class="p-4">
        <div class="rounded-md border border-dashed border-white/10 px-4 py-6 text-center">
          <p class="text-xs text-gray-500 mb-1">Team collaboration requires the Team plan</p>
          <p class="text-[11px] text-gray-600 mb-3">Invite members, manage roles, share reports</p>
          <a href="/pricing" class="inline-flex items-center gap-1.5 rounded-md bg-electric/15 border border-electric/20 px-3 py-1.5 text-xs font-medium text-electric hover:bg-electric/25 transition-colors">
            Upgrade
          </a>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
