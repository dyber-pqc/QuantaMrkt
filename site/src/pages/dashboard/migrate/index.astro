---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const reports = [
  {
    id: 'acme-backend',
    repo: 'acme/backend-services',
    date: '2026-03-22',
    critical: 12,
    high: 23,
    medium: 18,
    low: 14,
    status: 'Complete',
  },
  {
    id: 'globex-api',
    repo: 'globex/api-gateway',
    date: '2026-03-20',
    critical: 3,
    high: 8,
    medium: 15,
    low: 22,
    status: 'Complete',
  },
  {
    id: 'acme-frontend',
    repo: 'acme/frontend-app',
    date: '2026-03-25',
    critical: 0,
    high: 2,
    medium: 5,
    low: 9,
    status: 'In Progress',
  },
];
---

<DashboardLayout title="Migration Hub">
  <!-- Compact URL Input -->
  <div class="rounded-lg border border-white/5 bg-navy-800 p-4 mb-5">
    <form class="flex items-center gap-2">
      <input
        type="url"
        placeholder="https://github.com/org/repo"
        class="flex-1 rounded-md border border-white/10 bg-navy-900 px-3 py-1.5 text-sm text-white placeholder-gray-500 focus:border-electric/50 focus:outline-none focus:ring-1 focus:ring-electric/50 font-mono"
      />
      <button type="submit" class="inline-flex items-center gap-1.5 rounded-md bg-electric/15 border border-electric/20 px-3 py-1.5 text-xs font-medium text-electric hover:bg-electric/25 transition-colors whitespace-nowrap">
        Scan Repository
      </button>
    </form>
    <p class="text-[11px] text-gray-600 mt-1.5">Paste a GitHub repository URL to scan for quantum-vulnerable cryptography</p>
  </div>

  <!-- Recent Reports -->
  <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
    <div class="px-4 py-2.5 border-b border-white/5 flex items-center justify-between">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Recent Reports</h2>
      <span class="text-xs text-gray-600">{reports.length} reports</span>
    </div>
    <table class="w-full text-xs">
      <thead>
        <tr class="border-b border-white/5 text-gray-500">
          <th class="text-left font-medium px-4 py-2">Repository</th>
          <th class="text-left font-medium px-4 py-2 hidden sm:table-cell">Date</th>
          <th class="text-center font-medium px-4 py-2">Crit</th>
          <th class="text-center font-medium px-4 py-2">High</th>
          <th class="text-center font-medium px-4 py-2">Med</th>
          <th class="text-center font-medium px-4 py-2">Low</th>
          <th class="text-right font-medium px-4 py-2">Status</th>
        </tr>
      </thead>
      <tbody>
        {reports.map((report, i) => (
          <tr class={`border-b border-white/[0.03] hover:bg-white/[0.03] transition-colors ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`}>
            <td class="px-4 py-2.5">
              <a href={`/dashboard/migrate/report/${report.id}`} class="font-mono text-sm text-gray-300 hover:text-white transition-colors">
                {report.repo}
              </a>
            </td>
            <td class="px-4 py-2.5 text-gray-500 hidden sm:table-cell">{report.date}</td>
            <td class="px-4 py-2.5 text-center">
              {report.critical > 0 ? (
                <span class="font-mono font-semibold text-danger">{report.critical}</span>
              ) : (
                <span class="font-mono text-gray-600">0</span>
              )}
            </td>
            <td class="px-4 py-2.5 text-center">
              <span class="font-mono font-semibold text-warning">{report.high}</span>
            </td>
            <td class="px-4 py-2.5 text-center">
              <span class="font-mono text-electric">{report.medium}</span>
            </td>
            <td class="px-4 py-2.5 text-center">
              <span class="font-mono text-quantum">{report.low}</span>
            </td>
            <td class="px-4 py-2.5 text-right">
              <span class={`inline-flex items-center gap-1.5 text-xs ${
                report.status === 'Complete' ? 'text-quantum' : 'text-warning'
              }`}>
                <span class={`h-1.5 w-1.5 rounded-full ${
                  report.status === 'Complete' ? 'bg-quantum' : 'bg-warning'
                }`} />
                {report.status}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</DashboardLayout>
