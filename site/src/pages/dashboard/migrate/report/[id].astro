---
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';

const { id } = Astro.params;

const report = {
  id: 'acme-backend',
  repo: 'acme/backend-services',
  date: '2026-03-22',
  filesScanned: 1247,
  filesWithCrypto: 43,
  totalVulnerabilities: 67,
  breakdown: {
    critical: 12,
    high: 23,
    medium: 18,
    low: 14,
  },
  findings: [
    {
      severity: 'CRITICAL',
      file: 'src/auth/jwt.ts',
      line: 42,
      description: 'RSA-2048 key used for JWT signing — vulnerable to Shor\'s algorithm on cryptographically relevant quantum computers.',
      replacement: 'Replace with ML-DSA-65 using @quantmrkt/pqc-jose library.',
    },
    {
      severity: 'CRITICAL',
      file: 'src/crypto/keyExchange.ts',
      line: 118,
      description: 'ECDH P-256 key exchange — quantum-vulnerable elliptic curve Diffie-Hellman.',
      replacement: 'Replace with ML-KEM-768 hybrid key encapsulation (X25519 + ML-KEM).',
    },
    {
      severity: 'CRITICAL',
      file: 'src/tls/config.ts',
      line: 23,
      description: 'TLS 1.2 configuration with RSA key exchange — no forward secrecy against quantum adversaries.',
      replacement: 'Upgrade to TLS 1.3 with ML-KEM-768 key agreement via hybrid mode.',
    },
  ],
  effort: {
    automated: 52,
    manual: 15,
    total: 67,
    timeEstimate: '3-4 weeks',
    costEstimate: '$35,000 - $50,000',
  },
};


const total = report.breakdown.critical + report.breakdown.high + report.breakdown.medium + report.breakdown.low;
---

<DashboardLayout title="Migration Report">
  <!-- Back link -->
  <a href="/dashboard/migrate" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-electric transition-colors mb-6">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    Back to Migration Hub
  </a>

  <!-- Repo Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
    <div>
      <h2 class="font-mono text-xl font-bold text-white">{report.repo}</h2>
      <p class="text-sm text-gray-400 mt-1">Scanned on {report.date}</p>
    </div>
    <button class="btn-secondary mt-4 sm:mt-0 text-sm">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
      Export PDF
    </button>
  </div>

  <!-- Summary Stats -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 mb-6">
    <div class="card text-center">
      <p class="text-3xl font-bold text-white font-mono">{report.filesScanned.toLocaleString()}</p>
      <p class="text-sm text-gray-400 mt-1">Files Scanned</p>
    </div>
    <div class="card text-center">
      <p class="text-3xl font-bold text-electric font-mono">{report.filesWithCrypto}</p>
      <p class="text-sm text-gray-400 mt-1">Files with Crypto</p>
    </div>
    <div class="card text-center">
      <p class="text-3xl font-bold text-danger font-mono">{report.totalVulnerabilities}</p>
      <p class="text-sm text-gray-400 mt-1">Total Vulnerabilities</p>
    </div>
  </div>

  <!-- Breakdown Bar -->
  <div class="card mb-6">
    <h3 class="text-lg font-semibold text-white mb-4">Vulnerability Breakdown</h3>
    <div class="flex h-4 rounded-full overflow-hidden mb-4">
      <div class="bg-danger" style={`width: ${(report.breakdown.critical / total) * 100}%`} />
      <div class="bg-warning" style={`width: ${(report.breakdown.high / total) * 100}%`} />
      <div class="bg-electric" style={`width: ${(report.breakdown.medium / total) * 100}%`} />
      <div class="bg-quantum" style={`width: ${(report.breakdown.low / total) * 100}%`} />
    </div>
    <div class="flex flex-wrap gap-6 text-sm">
      <div class="flex items-center gap-2">
        <div class="h-3 w-3 rounded-sm bg-danger" />
        <span class="text-gray-400">Critical</span>
        <span class="font-mono font-semibold text-white">{report.breakdown.critical}</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="h-3 w-3 rounded-sm bg-warning" />
        <span class="text-gray-400">High</span>
        <span class="font-mono font-semibold text-white">{report.breakdown.high}</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="h-3 w-3 rounded-sm bg-electric" />
        <span class="text-gray-400">Medium</span>
        <span class="font-mono font-semibold text-white">{report.breakdown.medium}</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="h-3 w-3 rounded-sm bg-quantum" />
        <span class="text-gray-400">Low</span>
        <span class="font-mono font-semibold text-white">{report.breakdown.low}</span>
      </div>
    </div>
  </div>

  <!-- Critical Findings -->
  <div class="card mb-6">
    <h3 class="text-lg font-semibold text-white mb-4">Critical Findings</h3>
    <div class="space-y-4">
      {report.findings.map((finding) => (
        <div class="rounded-lg border border-danger/20 bg-danger/5 p-4">
          <div class="flex items-start justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="badge-critical">{finding.severity}</span>
              <span class="font-mono text-sm text-white">{finding.file}</span>
              <span class="text-xs text-gray-500">line {finding.line}</span>
            </div>
          </div>
          <p class="text-sm text-gray-300 mb-3">{finding.description}</p>
          <div class="rounded-md bg-navy-900/80 p-3">
            <p class="text-xs text-gray-500 mb-1">Recommended fix:</p>
            <p class="text-sm text-quantum font-mono">{finding.replacement}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Effort Estimate -->
  <div class="card">
    <h3 class="text-lg font-semibold text-white mb-4">Migration Effort Estimate</h3>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Automated Fixes</p>
        <p class="text-2xl font-bold text-quantum font-mono">{report.effort.automated}<span class="text-sm text-gray-500">/{report.effort.total}</span></p>
        <div class="mt-2 h-2 rounded-full bg-white/5 overflow-hidden">
          <div class="h-full rounded-full bg-quantum" style={`width: ${(report.effort.automated / report.effort.total) * 100}%`} />
        </div>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Manual Review</p>
        <p class="text-2xl font-bold text-warning font-mono">{report.effort.manual}</p>
        <p class="text-xs text-gray-500 mt-2">Requires developer intervention</p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Time Estimate</p>
        <p class="text-2xl font-bold text-white">{report.effort.timeEstimate}</p>
        <p class="text-xs text-gray-500 mt-2">Based on team of 2 engineers</p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Estimated Cost</p>
        <p class="text-2xl font-bold text-electric">{report.effort.costEstimate}</p>
        <p class="text-xs text-gray-500 mt-2">Including testing & validation</p>
      </div>
    </div>
  </div>
</DashboardLayout>
