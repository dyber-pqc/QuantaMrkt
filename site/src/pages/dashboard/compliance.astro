---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const complianceScore = 78;

const checklist = [
  { label: 'New systems using ML-KEM for key encapsulation', checked: true },
  { label: 'Firmware signing migrated to ML-DSA', checked: true },
  { label: 'Certificate infrastructure updated to PQC', checked: true },
  { label: 'Agent identities quantum-safe', checked: true },
  { label: 'Legacy TLS endpoints migrated (12 remaining)', checked: false },
  { label: 'Full audit completed', checked: false },
];

const deadline = new Date('2027-01-01T00:00:00');
const now = new Date();
const daysRemaining = Math.ceil((deadline.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
const completed = checklist.filter(i => i.checked).length;
---

<DashboardLayout title="CNSA 2.0 Compliance">
  <!-- Progress Bar Row -->
  <div class="rounded-lg border border-white/5 bg-navy-800 p-4 mb-5">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center gap-3">
        <span class="text-sm font-medium text-gray-300">CNSA 2.0 Compliance</span>
        <span class="text-xs text-gray-500">{completed}/{checklist.length} items</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-sm font-semibold font-mono text-white">{complianceScore}%</span>
        <span class="text-xs text-gray-500">|</span>
        <span class="text-xs text-warning font-mono">{daysRemaining}d remaining</span>
      </div>
    </div>
    <div class="h-1.5 rounded-full bg-white/5 overflow-hidden">
      <div
        class="h-full rounded-full bg-gradient-to-r from-electric to-quantum"
        style={`width: ${complianceScore}%`}
      />
    </div>
    <p class="text-[11px] text-gray-600 mt-1.5">Target: 100% by January 1, 2027 (software and firmware signing)</p>
  </div>

  <div class="grid grid-cols-1 gap-5 lg:grid-cols-4">
    <!-- Checklist -->
    <div class="lg:col-span-3 rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
      <div class="px-4 py-2.5 border-b border-white/5">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Compliance Checklist</h2>
      </div>
      <div class="divide-y divide-white/[0.03]">
        {checklist.map((item, i) => (
          <div class={`flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-white/[0.02] transition-colors compliance-item ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`} data-checked={item.checked ? 'true' : 'false'}>
            <div class={`compliance-box flex h-4 w-4 items-center justify-center rounded flex-shrink-0 ${
              item.checked ? 'bg-quantum/20' : 'border border-white/15'
            }`}>
              <svg class={`compliance-check h-2.5 w-2.5 text-quantum ${item.checked ? '' : 'hidden'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <span class={`text-sm ${item.checked ? 'text-gray-300' : 'text-gray-500'}`}>
              {item.label}
            </span>
          </div>
        ))}
      </div>
    </div>

    <!-- Sidebar Summary -->
    <div class="space-y-5">
      <!-- Deadline -->
      <div class="rounded-lg border border-white/5 bg-navy-800 p-4">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Deadline</h3>
        <p class="text-2xl font-bold text-warning font-mono">{daysRemaining}</p>
        <p class="text-xs text-gray-500 mt-0.5">days until Jan 2027</p>
      </div>

      <!-- Quick Stats -->
      <div class="rounded-lg border border-white/5 bg-navy-800 p-4">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Summary</h3>
        <div class="space-y-2 text-xs">
          <div class="flex items-center justify-between">
            <span class="text-gray-500">Models Signed</span>
            <span class="font-mono text-gray-300">1,247</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-500">Agents PQC-Ready</span>
            <span class="font-mono text-gray-300">891/892</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-500">Legacy Endpoints</span>
            <span class="font-mono text-warning">12 remaining</span>
          </div>
        </div>
      </div>
    </div>
  </div>
<script>
  document.querySelectorAll('.compliance-item').forEach(item => {
    item.addEventListener('click', () => {
      const el = item as HTMLElement;
      const isChecked = el.dataset.checked === 'true';
      el.dataset.checked = isChecked ? 'false' : 'true';
      const box = el.querySelector('.compliance-box') as HTMLElement;
      const check = el.querySelector('.compliance-check') as HTMLElement;
      if (!isChecked) {
        box.classList.remove('border', 'border-white/15');
        box.classList.add('bg-quantum/20');
        check.classList.remove('hidden');
      } else {
        box.classList.add('border', 'border-white/15');
        box.classList.remove('bg-quantum/20');
        check.classList.add('hidden');
      }
    });
  });
</script>
</DashboardLayout>
