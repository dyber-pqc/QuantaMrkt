---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import type { User } from '../../lib/auth';
import { getUserByGithubId, getUserStats, getActivity } from '../../lib/db';

const user = (Astro.locals as any).user as User | undefined;
const db = (Astro.locals as any).runtime?.env?.DB;

let dbUser: any = null;
let stats = { modelCount: 0, agentCount: 0, verificationCount: 0 };
let recentActivity: any[] = [];

if (db && user) {
  dbUser = await getUserByGithubId(db, (user as any).id ?? (user as any).github_id);
  if (dbUser) {
    stats = await getUserStats(db, dbUser.id);
    recentActivity = await getActivity(db, { userId: dbUser.id, limit: 5 });
  }
}

const memberSince = dbUser?.created_at
  ? new Date(dbUser.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : 'Unknown';
---

<DashboardLayout title="Profile">
  {user ? (
    <div class="max-w-3xl space-y-6">

      <!-- Profile Header -->
      <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
        <div class="p-6">
          <div class="flex items-start gap-5">
            {user.avatar_url ? (
              <img
                src={user.avatar_url}
                alt={user.login}
                class="h-20 w-20 rounded-full border-2 border-white/10"
              />
            ) : (
              <div class="flex h-20 w-20 items-center justify-center rounded-full bg-electric/20 text-2xl font-bold text-electric border-2 border-electric/20">
                {user.login?.[0]?.toUpperCase() || 'U'}
              </div>
            )}
            <div class="flex-1 min-w-0">
              <h2 class="text-xl font-bold text-white">{user.name || user.login}</h2>
              <p class="text-sm text-gray-400 mt-0.5">@{user.login}</p>
              {user.email && (
                <p class="text-sm text-gray-500 mt-1">{user.email}</p>
              )}
              <div class="flex items-center gap-3 mt-3">
                <span class="inline-flex items-center gap-1 rounded-md bg-electric/10 border border-electric/20 px-2 py-0.5 text-xs font-medium text-electric capitalize">
                  {dbUser?.tier || 'free'} tier
                </span>
                <span class="text-xs text-gray-500">Member since {memberSince}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-3">
        <div class="rounded-lg border border-white/5 bg-navy-800 p-4 text-center">
          <p class="text-2xl font-bold text-white font-mono">{stats.modelCount}</p>
          <p class="text-xs text-gray-500 mt-1">Models Pushed</p>
        </div>
        <div class="rounded-lg border border-white/5 bg-navy-800 p-4 text-center">
          <p class="text-2xl font-bold text-white font-mono">{stats.agentCount}</p>
          <p class="text-xs text-gray-500 mt-1">Agents Registered</p>
        </div>
        <div class="rounded-lg border border-white/5 bg-navy-800 p-4 text-center">
          <p class="text-2xl font-bold text-white font-mono">{stats.verificationCount}</p>
          <p class="text-xs text-gray-500 mt-1">Verifications Run</p>
        </div>
      </div>

      <!-- Connected Accounts -->
      <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-white/5">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Connected Accounts</h3>
        </div>
        <div class="p-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5">
                <svg class="h-5 w-5 text-gray-300" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-200">GitHub</p>
                <p class="text-xs text-gray-500">@{user.login}</p>
              </div>
            </div>
            <span class="inline-flex items-center gap-1 rounded-md bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 text-xs font-medium text-emerald-400">
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Connected
            </span>
          </div>
        </div>
      </div>

      <!-- Edit Profile (read-only for now) -->
      <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-white/5">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Edit Profile</h3>
        </div>
        <div class="p-4 space-y-4">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Display Name</label>
            <input
              type="text"
              value={user.name || user.login}
              disabled
              class="w-full rounded-md border border-white/10 bg-navy-900 px-3 py-2 text-sm text-gray-300 opacity-60 cursor-not-allowed"
            />
            <p class="text-[10px] text-gray-600 mt-1">Profile editing coming soon.</p>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Login</label>
            <input
              type="text"
              value={user.login}
              disabled
              class="w-full rounded-md border border-white/10 bg-navy-900 px-3 py-2 text-sm text-gray-300 opacity-60 cursor-not-allowed"
            />
            <p class="text-[10px] text-gray-600 mt-1">Managed by GitHub.</p>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Email</label>
            <input
              type="text"
              value={user.email || 'Not provided'}
              disabled
              class="w-full rounded-md border border-white/10 bg-navy-900 px-3 py-2 text-sm text-gray-300 opacity-60 cursor-not-allowed"
            />
            <p class="text-[10px] text-gray-600 mt-1">Managed by GitHub.</p>
          </div>
        </div>
      </div>

    </div>
  ) : (
    <div class="rounded-lg border border-white/5 bg-navy-800 px-4 py-16 text-center">
      <p class="text-sm text-gray-400 mb-3">You need to sign in to view your profile.</p>
      <a href="/api/auth/login" class="inline-flex items-center gap-1.5 rounded-md bg-electric/15 border border-electric/20 px-3 py-1.5 text-xs font-medium text-electric hover:bg-electric/25 transition-colors">
        Sign in with GitHub
      </a>
    </div>
  )}
</DashboardLayout>
