---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const { id } = Astro.params;

const agent = {
  id: 'finance-copilot',
  name: 'acme/finance-copilot',
  did: 'did:web:acme.corp:agents:finance-copilot',
  algorithm: 'ML-DSA-65',
  created: '2026-02-14T09:00:00Z',
  status: 'Active',
  capabilities: ['read:financial-data', 'write:reports', 'execute:analysis'],
  delegationChain: [
    { name: 'acme.corp Root', did: 'did:web:acme.corp:root', algorithm: 'ML-DSA-87', role: 'Root Authority' },
    { name: 'acme.corp Controller', did: 'did:web:acme.corp:controller:ops', algorithm: 'ML-DSA-65', role: 'Controller' },
    { name: 'finance-copilot', did: 'did:web:acme.corp:agents:finance-copilot', algorithm: 'ML-DSA-65', role: 'Agent' },
  ],
  history: [
    { action: 'Generated quarterly earnings report', timestamp: '2026-03-24T16:42:00Z', result: 'Success' },
    { action: 'Accessed financial-data:revenue-2026-q1', timestamp: '2026-03-24T14:18:00Z', result: 'Success' },
    { action: 'Credential renewed by controller', timestamp: '2026-03-20T09:00:00Z', result: 'Success' },
  ],
};


---

<DashboardLayout title={agent.name}>
  <!-- Back link -->
  <a href="/dashboard/agents" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-electric transition-colors mb-6">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    Back to Agent Directory
  </a>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <!-- Identity Info -->
    <div class="card">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-white">Identity</h3>
        <span class={`badge ${agent.status === 'Active' ? 'bg-quantum/20 text-quantum' : 'bg-danger/20 text-danger'}`}>
          {agent.status}
        </span>
      </div>
      <div class="space-y-4 text-sm">
        <div>
          <span class="text-gray-500 text-xs uppercase tracking-wider">DID</span>
          <p class="font-mono text-white mt-1 break-all text-xs">{agent.did}</p>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-gray-400">Algorithm</span>
          <span class="font-mono text-electric">{agent.algorithm}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-gray-400">Created</span>
          <span class="text-white">{new Date(agent.created).toLocaleDateString()}</span>
        </div>
      </div>

      <!-- Capabilities -->
      <div class="mt-6 pt-4 border-t border-white/5">
        <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-3">Capabilities</h4>
        <div class="space-y-2">
          {agent.capabilities.map((cap) => (
            <div class="flex items-center gap-2">
              <svg class="h-3.5 w-3.5 text-quantum flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="font-mono text-sm text-white">{cap}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Delegation Chain & History -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Delegation Chain -->
      <div class="card">
        <h3 class="text-lg font-semibold text-white mb-6">Delegation Chain</h3>
        <div class="flex flex-col md:flex-row items-start md:items-center gap-4">
          {agent.delegationChain.map((node, i) => (
            <div class="flex items-center gap-4 w-full md:w-auto">
              <div class={`flex-shrink-0 rounded-xl border p-4 w-full md:w-auto ${
                i === 0 ? 'border-electric/30 bg-electric/5' :
                i === agent.delegationChain.length - 1 ? 'border-quantum/30 bg-quantum/5' :
                'border-white/10 bg-white/5'
              }`}>
                <div class="flex items-center gap-2 mb-2">
                  <div class={`h-2 w-2 rounded-full ${
                    i === 0 ? 'bg-electric' :
                    i === agent.delegationChain.length - 1 ? 'bg-quantum' : 'bg-gray-400'
                  }`} />
                  <span class="text-xs font-medium text-gray-400">{node.role}</span>
                </div>
                <p class="text-sm font-semibold text-white mb-1">{node.name}</p>
                <p class="font-mono text-xs text-gray-500 break-all">{node.did.length > 35 ? node.did.slice(0, 35) + '...' : node.did}</p>
                <span class="mt-2 inline-block badge-verified text-xs">{node.algorithm}</span>
              </div>
              {i < agent.delegationChain.length - 1 && (
                <svg class="h-5 w-5 text-gray-600 flex-shrink-0 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Credential History -->
      <div class="card">
        <h3 class="text-lg font-semibold text-white mb-4">Credential History</h3>
        <div class="space-y-3">
          {agent.history.map((event) => (
            <div class="flex items-start gap-3 rounded-lg border border-white/5 bg-navy-900/50 p-4">
              <div class="mt-0.5 flex h-6 w-6 items-center justify-center rounded-full bg-quantum/20 flex-shrink-0">
                <svg class="h-3.5 w-3.5 text-quantum" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-white">{event.action}</p>
                <p class="text-xs text-gray-500 mt-1">{new Date(event.timestamp).toLocaleString()}</p>
              </div>
              <span class="badge bg-quantum/20 text-quantum text-xs flex-shrink-0">{event.result}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
