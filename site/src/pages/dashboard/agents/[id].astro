---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const { id } = Astro.params;

const agent = {
  id: 'finance-copilot',
  name: 'acme/finance-copilot',
  did: 'did:web:acme.corp:agents:finance-copilot',
  algorithm: 'ML-DSA-65',
  created: '2026-02-14T09:00:00Z',
  status: 'Active',
  capabilities: ['read:financial-data', 'write:reports', 'execute:analysis'],
  delegationChain: [
    { name: 'acme.corp Root', did: 'did:web:acme.corp:root', algorithm: 'ML-DSA-87', role: 'Root Authority' },
    { name: 'acme.corp Controller', did: 'did:web:acme.corp:controller:ops', algorithm: 'ML-DSA-65', role: 'Controller' },
    { name: 'finance-copilot', did: 'did:web:acme.corp:agents:finance-copilot', algorithm: 'ML-DSA-65', role: 'Agent' },
  ],
  history: [
    { action: 'Generated quarterly earnings report', timestamp: '2026-03-24T16:42:00Z', result: 'Success' },
    { action: 'Accessed financial-data:revenue-2026-q1', timestamp: '2026-03-24T14:18:00Z', result: 'Success' },
    { action: 'Credential renewed by controller', timestamp: '2026-03-20T09:00:00Z', result: 'Success' },
    { action: 'First credential issued', timestamp: '2026-02-14T09:00:00Z', result: 'Success' },
  ],
};
---

<DashboardLayout title={agent.name}>
  <a href="/dashboard/agents" class="inline-flex items-center gap-1 text-xs text-gray-500 hover:text-gray-300 transition-colors mb-3">
    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    Agents
  </a>

  <!-- Compact Header -->
  <div class="flex items-center gap-3 mb-5">
    <h2 class="font-mono text-base font-semibold text-white">{agent.name}</h2>
    <span class={`inline-flex items-center gap-1.5 text-xs ${
      agent.status === 'Active' ? 'text-quantum' : 'text-danger'
    }`}>
      <span class={`h-1.5 w-1.5 rounded-full ${
        agent.status === 'Active' ? 'bg-quantum' : 'bg-danger'
      }`} />
      {agent.status}
    </span>
    <span class="badge-verified">{agent.algorithm}</span>
  </div>

  <div class="grid grid-cols-1 gap-5 lg:grid-cols-3">
    <!-- Left: Identity Details -->
    <div class="space-y-5">
      <!-- Identity -->
      <div class="rounded-lg border border-white/5 bg-navy-800 p-4">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Identity</h3>
        <div class="space-y-3 text-xs">
          <div>
            <span class="text-gray-500">DID</span>
            <p class="font-mono text-gray-300 mt-0.5 break-all">{agent.did}</p>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-500">Algorithm</span>
            <span class="font-mono text-gray-300">{agent.algorithm}</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-500">Created</span>
            <span class="text-gray-300">{new Date(agent.created).toLocaleDateString()}</span>
          </div>
        </div>

        <div class="mt-3 pt-3 border-t border-white/5">
          <span class="text-xs text-gray-500 block mb-2">Capabilities</span>
          <div class="flex flex-wrap gap-1">
            {agent.capabilities.map((cap) => (
              <span class="rounded bg-white/5 px-1.5 py-0.5 font-mono text-[10px] text-gray-400">{cap}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Delegation Chain -->
    <div class="lg:col-span-2 space-y-5">
      <!-- Delegation Chain as vertical timeline -->
      <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-white/5">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Delegation Chain</h3>
        </div>
        <div class="p-4">
          {agent.delegationChain.map((node, i) => (
            <div class="flex items-start gap-3">
              <div class="flex flex-col items-center">
                <div class={`flex h-5 w-5 items-center justify-center rounded-full text-[10px] font-bold ${
                  i === 0 ? 'bg-electric/15 text-electric' :
                  i === agent.delegationChain.length - 1 ? 'bg-quantum/15 text-quantum' :
                  'bg-white/10 text-gray-400'
                }`}>
                  {i + 1}
                </div>
                {i < agent.delegationChain.length - 1 && (
                  <div class="w-px h-8 bg-white/10 my-1" />
                )}
              </div>
              <div class={`flex-1 ${i < agent.delegationChain.length - 1 ? 'pb-2' : ''}`}>
                <div class="flex items-center gap-2">
                  <span class="text-xs font-medium text-gray-300">{node.name}</span>
                  <span class="text-[10px] text-gray-600 rounded bg-white/5 px-1.5 py-0.5">{node.role}</span>
                  <span class="font-mono text-[10px] text-gray-500">{node.algorithm}</span>
                </div>
                <p class="font-mono text-xs text-gray-500 mt-0.5">{node.did}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Credential History -->
      <div class="rounded-lg border border-white/5 bg-navy-800 overflow-hidden">
        <div class="px-4 py-2.5 border-b border-white/5">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Credential History</h3>
        </div>
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-white/5 text-gray-500">
              <th class="text-left font-medium px-4 py-2">Timestamp</th>
              <th class="text-left font-medium px-4 py-2">Action</th>
              <th class="text-right font-medium px-4 py-2">Result</th>
            </tr>
          </thead>
          <tbody>
            {agent.history.map((event, i) => (
              <tr class={`border-b border-white/[0.03] ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`}>
                <td class="px-4 py-2 text-gray-500 whitespace-nowrap font-mono">{new Date(event.timestamp).toLocaleDateString()}</td>
                <td class="px-4 py-2 text-gray-300">{event.action}</td>
                <td class="px-4 py-2 text-right">
                  <span class="text-quantum">{event.result}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</DashboardLayout>
