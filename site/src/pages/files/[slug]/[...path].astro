---
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import { getModelBySlug } from '../../../lib/db';
import { fetchFile, escapeHtml, formatBytes } from '../../../lib/file-fetcher';

const slug = Astro.params.slug || '';
const rawPath = Astro.params.path || '';
// Normalize: strip trailing slash, remove leading slash
const filePath = String(rawPath).replace(/^\/+/, '').replace(/\/+$/, '');

const db = (Astro.locals as any).runtime?.env?.DB;

let model: any = null;
let files: any[] = [];
let viewed: any = null;
let error: string | null = null;

if (!db) {
  error = 'Database unavailable.';
} else if (!slug) {
  error = 'Missing slug.';
} else {
  try {
    model = await getModelBySlug(db, slug);
    if (!model) {
      error = `Model not found: ${slug}`;
    } else {
      // File tree for sidebar
      const latestVersion = model.versions?.[0];
      if (latestVersion) {
        const r = await db
          .prepare(`SELECT filename, size, sha3_256_hash FROM model_files WHERE version_id = ? ORDER BY filename`)
          .bind(latestVersion.id)
          .all<any>();
        files = r.results || [];
      }

      // Fetch the viewed file from source
      if (filePath && model.source_url) {
        try {
          viewed = await fetchFile(model.source_url, filePath);
        } catch (e: any) {
          error = e?.message || `Could not fetch ${filePath}`;
        }
      } else if (!model.source_url) {
        error = 'This model has no source_url registered, so we cannot fetch file contents.';
      }
    }
  } catch (e: any) {
    error = e?.message || 'Internal error';
  }
}

// Group files by directory for the tree
interface TreeDir { name: string; path: string; children: TreeNode[]; }
interface TreeFile { name: string; path: string; size: number; hash: string; }
type TreeNode = ({ kind: 'dir' } & TreeDir) | ({ kind: 'file' } & TreeFile);

function buildTree(flat: any[]): TreeNode[] {
  const root: TreeNode[] = [];
  const dirs = new Map<string, TreeDir>();

  for (const f of flat) {
    const parts = (f.filename as string).split('/');
    let currentChildren = root;
    for (let i = 0; i < parts.length - 1; i++) {
      const dirPath = parts.slice(0, i + 1).join('/');
      let dir = dirs.get(dirPath);
      if (!dir) {
        dir = { name: parts[i], path: dirPath, children: [] };
        dirs.set(dirPath, dir);
        currentChildren.push({ kind: 'dir', ...dir });
      }
      currentChildren = dir.children;
    }
    currentChildren.push({
      kind: 'file',
      name: parts[parts.length - 1],
      path: f.filename,
      size: f.size ?? 0,
      hash: f.sha3_256_hash ?? '',
    });
  }
  return root;
}

function sortTree(nodes: TreeNode[]): TreeNode[] {
  return [...nodes]
    .sort((a, b) => {
      if (a.kind !== b.kind) return a.kind === 'dir' ? -1 : 1;
      return a.name.localeCompare(b.name);
    })
    .map((n) => (n.kind === 'dir' ? { ...n, children: sortTree(n.children) } : n));
}

const tree = sortTree(buildTree(files));

// Flat list for rendering (with depth for indentation)
interface FlatRow { kind: 'dir' | 'file'; name: string; path: string; depth: number; size?: number; }
function flatten(nodes: TreeNode[], depth = 0): FlatRow[] {
  const out: FlatRow[] = [];
  for (const n of nodes) {
    if (n.kind === 'dir') {
      out.push({ kind: 'dir', name: n.name, path: n.path, depth });
      out.push(...flatten(n.children, depth + 1));
    } else {
      out.push({ kind: 'file', name: n.name, path: n.path, depth, size: n.size });
    }
  }
  return out;
}
const rows = flatten(tree);

// Breadcrumb segments for the viewed file path
const pathSegments = filePath ? filePath.split('/') : [];

const pageTitle = filePath
  ? `${filePath} · ${model?.name ?? slug}`
  : `Files · ${model?.name ?? slug}`;

function lineNumbers(count: number): number[] {
  return Array.from({ length: count }, (_, i) => i + 1);
}

const lineCount = viewed?.content ? viewed.content.split('\n').length : 0;
const sourceHost = viewed?.source_host ?? (model?.source_platform as string) ?? '';
---

<MarketingLayout
  title={pageTitle}
  description={`View ${filePath || 'files'} from ${model?.author ?? ''}/${model?.name ?? slug}`}
>
  <main class="mx-auto max-w-7xl px-4 sm:px-6 py-6">
    {error && !viewed && (
      <div class="rounded-xl border border-red-500/30 bg-red-500/5 p-5">
        <h1 class="text-lg font-bold text-red-400 mb-1">Can't show files</h1>
        <p class="text-sm text-gray-400">{error}</p>
        <a href={`/models/${slug}`} class="mt-3 inline-block text-sm text-electric hover:underline">← Back to {slug}</a>
      </div>
    )}

    {model && (
      <>
        {/* Breadcrumb */}
        <nav class="flex items-center gap-2 text-xs text-gray-500 mb-4 flex-wrap" aria-label="Breadcrumb">
          <a href="/models" class="hover:text-electric transition-colors">All</a>
          <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <a href={`/models/${slug}`} class="hover:text-electric transition-colors">{model.name}</a>
          <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-gray-400">Files</span>
          {pathSegments.map((seg, i) => (
            <>
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              {i === pathSegments.length - 1 ? (
                <span class="text-gray-300" aria-current="page">{seg}</span>
              ) : (
                <a
                  href={`/files/${slug}/${pathSegments.slice(0, i + 1).join('/')}`}
                  class="hover:text-electric transition-colors"
                >{seg}</a>
              )}
            </>
          ))}
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-4">
          {/* File tree sidebar */}
          <aside class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden lg:sticky lg:top-20 lg:self-start lg:max-h-[calc(100vh-6rem)]">
            <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                <h2 class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Files</h2>
              </div>
              <span class="text-[10px] text-gray-500">{files.length}</span>
            </div>
            <div class="overflow-y-auto lg:max-h-[calc(100vh-10rem)] py-1">
              {rows.length === 0 ? (
                <div class="px-4 py-6 text-xs text-gray-500">No files in version manifest.</div>
              ) : (
                rows.map((row) => {
                  const active = row.kind === 'file' && row.path === filePath;
                  const indent = `padding-left: ${12 + row.depth * 14}px`;
                  if (row.kind === 'dir') {
                    return (
                      <div class="flex items-center gap-1.5 py-0.5 text-xs" style={indent}>
                        <svg class="h-3 w-3 text-electric/60 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"/></svg>
                        <span class="text-gray-400 font-medium">{row.name}</span>
                      </div>
                    );
                  }
                  return (
                    <a
                      href={`/files/${slug}/${row.path}`}
                      class:list={[
                        'flex items-center gap-1.5 py-0.5 text-xs transition-colors group',
                        active ? 'bg-electric/10 text-electric' : 'text-gray-300 hover:bg-white/5',
                      ]}
                      style={indent}
                    >
                      <svg class="h-3 w-3 flex-shrink-0 text-gray-500 group-hover:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      <span class="truncate font-mono">{row.name}</span>
                    </a>
                  );
                })
              )}
            </div>
          </aside>

          {/* Main viewer */}
          <section class="min-w-0">
            {!filePath && (
              <div class="rounded-xl border border-white/5 bg-navy-800 p-8 text-center">
                <svg class="h-10 w-10 text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <h2 class="text-lg font-semibold text-gray-300">Pick a file to view</h2>
                <p class="text-sm text-gray-500 mt-1">Source-code files from {sourceHost || 'the registered source'} are rendered with syntax highlighting.</p>
              </div>
            )}

            {viewed && (
              <div class="rounded-xl border border-white/5 bg-navy-800 overflow-hidden">
                {/* Toolbar */}
                <div class="flex items-center justify-between gap-3 px-4 py-2.5 border-b border-white/5 bg-navy-900/30">
                  <div class="flex items-center gap-2 min-w-0">
                    <svg class="h-4 w-4 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <span class="font-mono text-sm text-gray-200 truncate" title={viewed.path}>{viewed.path}</span>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0 text-[10px] text-gray-500">
                    <span>{formatBytes(viewed.size)}</span>
                    {viewed.content && <span>· {lineCount} lines</span>}
                    <span class="uppercase tracking-wider">· {viewed.language}</span>
                    <a
                      href={viewed.raw_url}
                      target="_blank"
                      rel="noopener"
                      class="ml-2 rounded border border-white/10 px-2 py-1 text-[10px] text-gray-300 hover:bg-white/5 transition-colors"
                      title="Open raw file in new tab"
                    >Raw</a>
                    {viewed.content && (
                      <button
                        id="copy-file-btn"
                        class="rounded border border-white/10 px-2 py-1 text-[10px] text-gray-300 hover:bg-white/5 transition-colors"
                      >Copy</button>
                    )}
                  </div>
                </div>

                {/* Viewer body */}
                {viewed.is_binary && (
                  <div class="p-10 text-center">
                    <svg class="h-10 w-10 text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                    <p class="text-sm text-gray-400">Binary file ({formatBytes(viewed.size)}) — not shown.</p>
                    <a href={viewed.raw_url} target="_blank" rel="noopener" class="mt-3 inline-block text-xs text-electric hover:underline">Download from source →</a>
                  </div>
                )}

                {viewed.is_too_large && (
                  <div class="p-10 text-center">
                    <p class="text-sm text-gray-400">File is {formatBytes(viewed.size)} — too large to render inline.</p>
                    <a href={viewed.raw_url} target="_blank" rel="noopener" class="mt-3 inline-block text-xs text-electric hover:underline">View raw file →</a>
                  </div>
                )}

                {viewed.content && (
                  <div class="overflow-x-auto">
                    <table class="font-mono text-[12.5px] leading-[1.55] w-full">
                      <tbody>
                        {viewed.content.split('\n').map((line: string, i: number) => (
                          <tr class="hover:bg-white/[0.02]">
                            <td class="select-none text-right pr-3 pl-3 text-gray-600 border-r border-white/5 sticky left-0 bg-navy-800" style="min-width: 3em;">
                              {i + 1}
                            </td>
                            <td id={i === 0 ? 'code-cell' : undefined} class="pl-4 pr-4 text-gray-200 whitespace-pre">
                              <code class={`language-${viewed.language}`} set:text={line || ' '} />
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            )}

            {error && !viewed && filePath && (
              <div class="rounded-xl border border-red-500/20 bg-red-500/5 p-5">
                <p class="text-sm text-red-400">{error}</p>
              </div>
            )}
          </section>
        </div>
      </>
    )}
  </main>

  {/* highlight.js from CDN — only loaded when there's content */}
  {viewed?.content && (
    <>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.10.0/build/styles/github-dark.min.css" />
      <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.10.0/build/highlight.min.js" is:inline></script>
      <script is:inline define:vars={{ lang: viewed.language, raw: viewed.content }}>
        // Highlight the whole file once, then split into per-line spans so
        // the existing line-number column stays aligned.
        document.addEventListener('DOMContentLoaded', () => {
          if (typeof hljs === 'undefined') return;
          const safe = hljs.getLanguage(lang) ? lang : 'plaintext';
          const result = hljs.highlight(raw, { language: safe, ignoreIllegals: true });
          const htmlLines = result.value.split('\n');
          document.querySelectorAll('td.pl-4 code').forEach((el, i) => {
            if (htmlLines[i] !== undefined) {
              el.innerHTML = htmlLines[i] || '&nbsp;';
            }
          });
        });
      </script>
    </>
  )}

  <script>
    const btn = document.getElementById('copy-file-btn');
    btn?.addEventListener('click', async () => {
      // Grab lines from the rendered table
      const rows = document.querySelectorAll('td.pl-4 code');
      const text = Array.from(rows).map((r) => r.textContent ?? '').join('\n');
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => { btn.textContent = original ?? 'Copy'; }, 1200);
      } catch {
        // ignore
      }
    });
  </script>
</MarketingLayout>
