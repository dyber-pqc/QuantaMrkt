<script>
  // Auto-detect OS
  const ua = navigator.userAgent.toLowerCase();
  const osName = document.getElementById('os-name');
  const osCommand = document.getElementById('os-command');
  const osCopy = document.getElementById('os-copy');

  let detectedOS = 'Linux';
  let installCmd = 'curl -fsSL https://quantamrkt.com/install.sh | sh';

  if (ua.includes('win')) {
    detectedOS = 'Windows';
    installCmd = 'irm https://quantamrkt.com/install.ps1 | iex';
  } else if (ua.includes('mac') || ua.includes('darwin')) {
    detectedOS = 'macOS';
    installCmd = 'curl -fsSL https://quantamrkt.com/install.sh | sh';
  } else if (ua.includes('freebsd')) {
    detectedOS = 'FreeBSD';
  }

  if (osName) osName.textContent = detectedOS;
  if (osCommand) osCommand.textContent = installCmd;
  if (osCopy) osCopy.dataset.copy = installCmd;

  // Copy-to-clipboard
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      await navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig || ''; }, 1500);
    });
  });
</script>
</MarketingLayout>
