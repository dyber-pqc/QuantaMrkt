---
import BaseLayout from './BaseLayout.astro';
import { NAV_ITEMS, SITE } from '../lib/constants';
import type { User } from '../lib/auth';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  canonical?: string;
}

const { title, description, ogImage, ogImageWidth, ogImageHeight, canonical } = Astro.props;
const currentPath = Astro.url.pathname;
const user = (Astro.locals as any).user as User | undefined;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogImageWidth={ogImageWidth}
  ogImageHeight={ogImageHeight}
  canonical={canonical}
>
  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-navy-900/80 backdrop-blur-xl">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-electric/20">
          <span class="text-lg font-bold text-electric">Q</span>
        </div>
        <span class="text-lg font-bold">{SITE.name}</span>
      </a>

      <div class="hidden items-center gap-8 md:flex">
        {NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm transition-colors duration-200',
              currentPath === item.href ? 'text-electric' : 'text-gray-400 hover:text-white',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-4">
        <a href={SITE.github} class="btn-ghost text-sm hidden sm:inline-flex" target="_blank" rel="noopener">
          GitHub
        </a>
        {user ? (
          <a href="/dashboard" class="flex items-center gap-2 text-sm text-white hover:text-electric transition-colors">
            <img
              src={user.avatar_url}
              alt={user.login}
              class="h-7 w-7 rounded-full border border-white/10"
            />
            <span class="hidden sm:inline">{user.name || user.login}</span>
          </a>
        ) : (
          <a href="/api/auth/login" class="btn-primary text-sm hidden sm:inline-flex">
            Sign In
          </a>
        )}
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center h-9 w-9 rounded-lg border border-white/10 text-gray-400 hover:text-white hover:bg-white/5 transition-colors" aria-label="Menu">
          <svg id="menu-open-icon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
          <svg id="menu-close-icon" class="h-5 w-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-navy-900/95 backdrop-blur-xl">
      <div class="px-6 py-4 space-y-1">
        {NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            class:list={[
              'block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
              currentPath === item.href ? 'bg-electric/10 text-electric' : 'text-gray-400 hover:bg-white/5 hover:text-white',
            ]}
          >
            {item.label}
          </a>
        ))}
        <div class="border-t border-white/5 pt-3 mt-3 space-y-1">
          <a href={SITE.github} class="block rounded-lg px-3 py-2.5 text-sm text-gray-400 hover:bg-white/5 hover:text-white transition-colors" target="_blank" rel="noopener">
            GitHub
          </a>
          {user ? (
            <a href="/dashboard" class="flex items-center gap-2 rounded-lg px-3 py-2.5 text-sm text-white hover:bg-white/5 transition-colors">
              <img src={user.avatar_url} alt={user.login} class="h-6 w-6 rounded-full border border-white/10" />
              {user.name || user.login}
            </a>
          ) : (
            <a href="/api/auth/login" class="block rounded-lg bg-electric/15 border border-electric/20 px-3 py-2.5 text-sm font-medium text-electric text-center hover:bg-electric/25 transition-colors">
              Sign In
            </a>
          )}
        </div>
      </div>
    </div>
  </header>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const openIcon = document.getElementById('menu-open-icon');
    const closeIcon = document.getElementById('menu-close-icon');
    btn?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden');
      openIcon?.classList.toggle('hidden', !isOpen);
      closeIcon?.classList.toggle('hidden', isOpen);
    });
  </script>

  <!-- Main Content -->
  <main class="pt-[73px]">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/5 bg-navy-900">
    <div class="mx-auto max-w-7xl px-6 py-16">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        <div>
          <h3 class="mb-4 text-sm font-semibold text-white">Products</h3>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/features#pq-aid" class="hover:text-white transition-colors">PQ-AID</a></li>
            <li><a href="/features#migrator" class="hover:text-white transition-colors">Migrator</a></li>
            <li><a href="/features#shield" class="hover:text-white transition-colors">Shield Registry</a></li>
            <li><a href="/pricing" class="hover:text-white transition-colors">Pricing</a></li>
          </ul>
        </div>
        <div>
          <h3 class="mb-4 text-sm font-semibold text-white">Developers</h3>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/docs" class="hover:text-white transition-colors">Documentation</a></li>
            <li><a href="/docs/api-reference" class="hover:text-white transition-colors">API Reference</a></li>
            <li><a href="/docs/quickstart" class="hover:text-white transition-colors">Quickstart</a></li>
            <li><a href={SITE.github} class="hover:text-white transition-colors">GitHub</a></li>
          </ul>
        </div>
        <div>
          <h3 class="mb-4 text-sm font-semibold text-white">Company</h3>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
            <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
            <li><a href="/careers" class="hover:text-white transition-colors">Careers</a></li>
            <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
          </ul>
        </div>
        <div>
          <h3 class="mb-4 text-sm font-semibold text-white">Legal</h3>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/privacy" class="hover:text-white transition-colors">Privacy</a></li>
            <li><a href="/terms" class="hover:text-white transition-colors">Terms</a></li>
            <li><a href="/security" class="hover:text-white transition-colors">Security</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-12 border-t border-white/5 pt-8 text-center text-sm text-gray-500">
        &copy; {new Date().getFullYear()} Dyber PQC. All rights reserved.
      </div>
    </div>
  </footer>
</BaseLayout>
