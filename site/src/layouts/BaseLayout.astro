---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  canonical?: string;
}

const {
  title = 'QuantaMrkt',
  description = 'The Quantum-Safe AI Marketplace',
  ogImage = 'https://quantamrkt.com/og-image.png',
  ogImageWidth = 1200,
  ogImageHeight = 630,
  canonical,
} = Astro.props;
const fullTitle = title === 'QuantaMrkt' ? title : `${title} | QuantaMrkt`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, 'https://quantamrkt.com').href;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'QuantaMrkt',
  url: 'https://quantamrkt.com',
  description: 'The Quantum-Safe AI Marketplace',
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:site_name" content="QuantaMrkt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect to Google Fonts for faster font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Inline critical CSS to prevent FOUC (flash of unstyled content) -->
    <style is:inline>
      html {
        background-color: #0a0f1e;
        color: #f3f4f6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background-color: #0a0f1e;
      }
      html:not(.css-loaded) body > * {
        opacity: 0;
      }
      html.css-loaded body > * {
        opacity: 1;
        transition: opacity 120ms ease-in;
      }
    </style>

    <title>{fullTitle}</title>
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Mark CSS as loaded to reveal content smoothly -->
    <script is:inline>
      // Reveal content as soon as stylesheets are applied
      function markCssLoaded() {
        document.documentElement.classList.add('css-loaded');
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', markCssLoaded);
      } else {
        markCssLoaded();
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
